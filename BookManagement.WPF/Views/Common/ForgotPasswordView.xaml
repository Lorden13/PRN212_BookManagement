<Page x:Class="BookManagement.Views.Common.ForgotPasswordView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BookManagement.Views.Common"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="Quên mật khẩu">

    <Grid Background="#F8F9FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/> <!-- Left Splash -->
            <ColumnDefinition Width="2*"/> <!-- Right Input Panel -->
        </Grid.ColumnDefinitions>

        <!-- Left Splash Panel (Purple Gradient and Branding) -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B21B6" Offset="0.0"/> <!-- Deep Purple -->
                    <GradientStop Color="#7C3AED" Offset="0.6"/> <!-- Medium Purple -->
                    <GradientStop Color="#A78BFA" Offset="1.0"/> <!-- Light Purple Accent -->
                </LinearGradientBrush>
            </Border.Background>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50">
                <StackPanel MaxWidth="500">
                    <!-- Logo Icon -->
                    <Border Width="80" Height="80" CornerRadius="40" Background="#33FFFFFF" Margin="0,0,0,24" HorizontalAlignment="Left">
                        <Path Data="{StaticResource IconBook}" 
                              Fill="#FFFFFF" 
                              Width="40" Height="40" 
                              Stretch="Uniform"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Border>
                    <!-- App Title -->
                    <TextBlock Text="Hệ thống Quản lý Sách" 
                               Foreground="#FFFFFF" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <TextBlock Text="BOOK MANAGEMENT SYSTEM" 
                               Foreground="#E9D5FF" 
                               FontSize="14" 
                               FontWeight="Heavy" 
                               Margin="0,4,0,20"
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <!-- Slogan/Description -->
                    <TextBlock Text="Nền tảng kết nối Độc giả, Tác giả và Ban quản trị. Trải nghiệm tìm kiếm, đăng tải và kiểm duyệt sách thông minh, trực quan và tối ưu nhất." 
                               Foreground="#F3E8FF" 
                               FontSize="15" 
                               LineHeight="24"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource MainFontFamily}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel (Authentication Panel) -->
        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
            <Grid Width="360">
                
                <!-- ==================== STEP 1: ENTER EMAIL ==================== -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Header -->
                    <TextBlock Text="Forgot Password?" 
                               Style="{StaticResource TextBlockLargeHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Nhập địa chỉ email của bạn để nhận mã xác thực OTP khôi phục mật khẩu." 
                               Style="{StaticResource TextBlockNormal}" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,24"/>

                    <!-- Email Field -->
                    <TextBlock Text="Email *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Nhập email của bạn..." 
                             Margin="0,0,0,16"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{DynamicResource DangerBrush}" 
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Left"
                               Margin="0,8,0,16"
                               FontFamily="{StaticResource MainFontFamily}"/>

                    <!-- Send OTP Button -->
                    <Button Command="{Binding SendOtpCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            Content="Gửi mã OTP"
                            Height="46"
                            Margin="0,0,0,24"/>

                    <!-- Back to Login -->
                    <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource MainFontFamily}" FontSize="14">
                        <Hyperlink Command="{Binding BackToLoginCommand}" Foreground="{DynamicResource PrimaryPurpleBrush}" TextDecorations="None">
                            <Bold>Quay lại đăng nhập</Bold>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- ==================== STEP 2: RESET PASSWORD ==================== -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Header -->
                    <TextBlock Text="Đặt lại mật khẩu" 
                               Style="{StaticResource TextBlockLargeHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Mã OTP đã được gửi. Nhập mã và mật khẩu mới bên dưới để đặt lại." 
                               Style="{StaticResource TextBlockNormal}" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,24"/>

                    <!-- OTP Field -->
                    <TextBlock Text="Mã OTP *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding Otp, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Nhập mã OTP 6 chữ số..." 
                             Margin="0,0,0,16"/>

                    <!-- New Password Field -->
                    <TextBlock Text="Mật khẩu mới *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <!-- Masked Password -->
                        <PasswordBox x:Name="txtNewPassword" 
                                     Style="{StaticResource ModernPasswordBox}" 
                                     Tag="Nhập mật khẩu mới..." 
                                   
                                     />
                        
                        <!-- Plain Text Password -->
                        <TextBox x:Name="txtNewPasswordPlain" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="Nhập mật khẩu mới..." 
                                 Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="txtNewPasswordPlain_TextChanged"
                                 />
                        
                        <!-- Toggle Visibility Button -->
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding ToggleNewPasswordVisibilityCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center" 
                                Margin="0,0,12,0"
                                Cursor="Hand">
                            <Path Fill="{DynamicResource TextSecondaryBrush}" 
                                  Width="18" Height="18" 
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconEye}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconEyeOff}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>

                    <!-- Confirm Password Field -->
                    <TextBlock Text="Xác nhận mật khẩu *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <!-- Masked Password -->
                        <PasswordBox x:Name="txtConfirmPassword" 
                                     Style="{StaticResource ModernPasswordBox}" 
                                     Tag="Nhập lại mật khẩu mới..." 
                                     
                                     />
                        
                        <!-- Plain Text Password -->
                        <TextBox x:Name="txtConfirmPasswordPlain" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="Nhập lại mật khẩu mới..." 
                                 Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="txtConfirmPasswordPlain_TextChanged"
                                 />
                        
                        <!-- Toggle Visibility Button -->
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center" 
                                Margin="0,0,12,0"
                                Cursor="Hand">
                            <Path Fill="{DynamicResource TextSecondaryBrush}" 
                                  Width="18" Height="18" 
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconEye}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConfirmPasswordVisible}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconEyeOff}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{DynamicResource DangerBrush}" 
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Left"
                               Margin="0,8,0,16"
                               
                               FontFamily="{StaticResource MainFontFamily}"/>

                    <!-- Reset Password Button -->
                    <Button Command="{Binding ResetPasswordCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            Content="Đặt lại mật khẩu"
                            Height="46"
                            Margin="0,0,0,24"/>

                    <!-- Back to Login -->
                    <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource MainFontFamily}" FontSize="14">
                        <Hyperlink Command="{Binding BackToLoginCommand}" Foreground="{DynamicResource PrimaryPurpleBrush}" TextDecorations="None">
                            <Bold>Quay lại đăng nhập</Bold>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Grid>
    </Grid>
</Page>
