<Page x:Class="BookManagement.Views.Common.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BookManagement.Views"
      xmlns:vm="clr-namespace:BookManagement.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="Đăng nhập">


    <Grid Background="#F8F9FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <!-- Left Splash -->
            <ColumnDefinition Width="2*"/>
            <!-- Right Login Buttons -->
        </Grid.ColumnDefinitions>

        <!-- Left Splash Panel (Purple Gradient and Branding) -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B21B6" Offset="0.0"/>
                    <!-- Deep Purple -->
                    <GradientStop Color="#7C3AED" Offset="0.6"/>
                    <!-- Medium Purple -->
                    <GradientStop Color="#A78BFA" Offset="1.0"/>
                    <!-- Light Purple Accent -->
                </LinearGradientBrush>
            </Border.Background>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50">
                <StackPanel MaxWidth="500">
                    <!-- Logo Icon -->
                    <Border Width="80" Height="80" CornerRadius="40" Background="#33FFFFFF" Margin="0,0,0,24" HorizontalAlignment="Left">
                        <Path Data="{StaticResource IconBook}" 
                              Fill="#FFFFFF" 
                              Width="40" Height="40" 
                              Stretch="Uniform"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Border>
                    <!-- App Title -->
                    <TextBlock Text="Hệ thống Quản lý Sách" 
                               Foreground="#FFFFFF" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <TextBlock Text="BOOK MANAGEMENT SYSTEM" 
                               Foreground="#E9D5FF" 
                               FontSize="14" 
                               FontWeight="Heavy" 
                               Margin="0,4,0,20"
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <!-- Slogan/Description -->
                    <TextBlock Text="Nền tảng kết nối Độc giả, Tác giả và Ban quản trị. Trải nghiệm tìm kiếm, đăng tải và kiểm duyệt sách thông minh, trực quan và tối ưu nhất." 
                               Foreground="#F3E8FF" 
                               FontSize="15" 
                               LineHeight="24"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource MainFontFamily}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel (Authentication Panel) -->
        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
            <Grid Width="360">
                <!-- ==================== LOGIN FORM ==================== -->
                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisInvertConverter}}">
                    <!-- Welcome header -->
                    <TextBlock Text="Welcome back!" 
                               Style="{StaticResource TextBlockLargeHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Đăng nhập vào tài khoản của bạn để tiếp tục khám phá hệ thống." 
                               Style="{StaticResource TextBlockNormal}" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,24"/>
                    <TextBlock Text="Vai trò *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                    <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding Roles}"
                                  x:Name="loginRole"
                                  Margin="0,0,0,24"/>
                    <!-- Email Field -->
                    <TextBlock Text="Email *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="txtEmail"
                             Style="{StaticResource ModernTextBox}" 
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Nhập email của bạn..." 
                             Margin="0,0,0,16"/>

                    <!-- Password Field -->
                    <TextBlock Text="Mật khẩu *" 
                               Style="{StaticResource TextBlockSmallHeader}" 
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <!-- Masked Password -->
                        <PasswordBox x:Name="txtPassword" 
                                     Style="{StaticResource ModernPasswordBox}" 
                                     Tag="Nhập mật khẩu của bạn..." 
                                     PasswordChanged="PasswordBox_PasswordChanged" 
                                     Visibility="{Binding IsLoginPasswordVisible, Converter={StaticResource BoolToVisInvertConverter}}"/>

                        <!-- Plain Text Password -->
                        <TextBox x:Name="txtPasswordPlain" 
                                 Style="{StaticResource ModernTextBox}" 
                                 Tag="Nhập mật khẩu của bạn..." 
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="txtPasswordPlain_TextChanged"
                                 Visibility="{Binding IsLoginPasswordVisible, Converter={StaticResource BoolToVisConverter}}"/>

                        <!-- Toggle Visibility Button -->
                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding ToggleLoginPasswordVisibilityCommand}"
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center" 
                                Margin="0,0,12,0"
                                Cursor="Hand">
                            <Path Fill="{DynamicResource TextSecondaryBrush}" 
                                  Width="18" Height="18" 
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconEye}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoginPasswordVisible}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconEyeOff}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>



                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{DynamicResource DangerBrush}" 
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Left"
                               Margin="0,8,0,16"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringNullOrEmptyToVisConverter}}"
                               FontFamily="{StaticResource MainFontFamily}"/>

                    <!-- Login Button -->
                    <Button 
                            Content="Đăng nhập"
                            Click="Button_Click_Login"
                            Height="46"
                            Margin="0,0,0,16"/>

                    <!-- Switch to Register Link -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" FontFamily="{StaticResource MainFontFamily}" FontSize="14">
                        <Run Text="Chưa có tài khoản?" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Hyperlink Command="{Binding SwitchToRegisterCommand}" Foreground="{DynamicResource PrimaryPurpleBrush}" TextDecorations="None">
                            <Bold>Đăng ký ngay</Bold>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- ==================== REGISTER FORM ==================== -->
                <ScrollViewer Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisConverter}}" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled" 
                              MaxHeight="500" 
                              Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Register header -->
                        <TextBlock Text="Đăng ký tài khoản" 
                                   Style="{StaticResource TextBlockLargeHeader}" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Đăng ký vai trò Độc giả hoặc Tác giả để bắt đầu." 
                                   Style="{StaticResource TextBlockNormal}" 
                                   TextWrapping="Wrap" 
                                   Margin="0,0,0,24"/>

                        <!-- Full Name Field -->
                        <TextBlock Text="Họ và tên *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Tag="Nhập họ và tên..." 
                                 x:Name="registerFullname"
                                 Margin="0,0,0,16"/>

                        <!-- Email Field -->
                        <TextBlock Text="Email *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}"                    
                                 Tag="Nhập địa chỉ email..." 
                                 x:Name="registerEmail"
                                 Margin="0,0,0,16"/>

                        <!-- Phone Number Field -->
                        <TextBlock Text="Số điện thoại *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}"                               
                                 Tag="Nhập số điện thoại..." 
                                 x:Name="registerPhone"
                                 MaxLength="11" 
                                 PreviewTextInput="NumberValidationTextBox" 
                                 Margin="0,0,0,16"/>

                        <!-- Address Field -->
                        <TextBlock Text="Địa chỉ *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Tag="Nhập địa chỉ..." 
                                 x:Name="registerAddress"
                                 MaxLength="255" 
                                 Margin="0,0,0,16"/>

                        <!-- Password Field -->
                        <TextBlock Text="Mật khẩu *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <!-- Masked Password -->
                            <PasswordBox x:Name="txtRegisterPassword" 
                                         Style="{StaticResource ModernPasswordBox}" 
                                         Tag="Nhập mật khẩu..." 
                                         PasswordChanged="PasswordBox_PasswordChanged" 
                                         Visibility="{Binding IsRegisterPasswordVisible, Converter={StaticResource BoolToVisInvertConverter}}"/>

                            <!-- Plain Text Password -->
                            <TextBox x:Name="txtRegisterPasswordPlain" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Tag="Nhập mật khẩu..." 
                                     TextChanged="txtRegisterPasswordPlain_TextChanged"
                                     Visibility="{Binding IsRegisterPasswordVisible, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- Toggle Visibility Button -->
                            <Button Style="{StaticResource IconButton}" 
                                    Command="{Binding ToggleRegisterPasswordVisibilityCommand}"
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" 
                                    Margin="0,0,12,0"
                                    Cursor="Hand">
                                <Path Fill="{DynamicResource TextSecondaryBrush}" 
                                      Width="18" Height="18" 
                                      Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource IconEye}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRegisterPasswordVisible}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource IconEyeOff}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </Grid>

                        <!-- Confirm Password Field -->
                        <TextBlock Text="Xác nhận mật khẩu *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <!-- Masked Password -->
                            <PasswordBox x:Name="txtRegisterConfirmPassword" 
                                         Style="{StaticResource ModernPasswordBox}" 
                                         Tag="Nhập lại mật khẩu..." 
                                         PasswordChanged="PasswordBox_PasswordChanged" 
                                         Visibility="{Binding IsRegisterConfirmPasswordVisible, Converter={StaticResource BoolToVisInvertConverter}}"/>

                            <!-- Plain Text Password -->
                            <TextBox x:Name="txtRegisterConfirmPasswordPlain" 
                                     Style="{StaticResource ModernTextBox}" 
                                     Tag="Nhập lại mật khẩu..." 
                                     Text="{Binding RegisterConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="txtRegisterConfirmPasswordPlain_TextChanged"
                                     Visibility="{Binding IsRegisterConfirmPasswordVisible, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- Toggle Visibility Button -->
                            <Button Style="{StaticResource IconButton}" 
                            Command="{Binding ToggleRegisterConfirmPasswordVisibilityCommand}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,12,0"
                            Cursor="Hand"
                            Panel.ZIndex="1">
                                <Path Fill="{DynamicResource TextSecondaryBrush}" 
                                Width="18" Height="18" 
                                Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource IconEye}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRegisterConfirmPasswordVisible}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource IconEyeOff}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </Grid>

                        <!-- Role ComboBox Field -->
                        <TextBlock Text="Vai trò *"
                                   Style="{StaticResource TextBlockSmallHeader}" 
                                   Margin="0,0,0,8"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding Roles}"
                                  x:Name="registerRole"
                                  Margin="0,0,0,24"/>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{DynamicResource DangerBrush}" 
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Left"
                                   Margin="0,8,0,16"
                                  
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringNullOrEmptyToVisConverter}}"
                                   FontFamily="{StaticResource MainFontFamily}"/>

                        <TextBlock x:Name="Message" 
           Foreground="#DC2626" 
           FontSize="13" 
           FontWeight="SemiBold" 
           TextWrapping="Wrap" 
           HorizontalAlignment="Center" 
           Margin="0,8,0,16"/>

                        <!-- Register Button -->
                        <Button 
                            
                                Content="Đăng ký"
                                Click="Button_Click_Register"
                                Height="46"
                                Margin="0,0,0,16"/>

                        <!-- Switch to Login Link -->
                        <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" FontFamily="{StaticResource MainFontFamily}" FontSize="14">
                            <Run Text="Đã có tài khoản?" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <Hyperlink Command="{Binding SwitchToLoginCommand}" Foreground="{DynamicResource PrimaryPurpleBrush}" TextDecorations="None">
                                <Bold>Đăng nhập</Bold>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
      
    </Grid>
</Page>
