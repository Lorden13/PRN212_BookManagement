<UserControl x:Class="BookManagement.Views.Author.AuthorReviewHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search bar -->
            <RowDefinition Height="*"/>    <!-- DataGrid Table -->
        </Grid.RowDefinitions>

        <!-- Search Header -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid Width="300" HorizontalAlignment="Left">
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Tìm kiếm theo tiêu đề sách hoặc kết quả..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>
            </Grid>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid ItemsSource="{Binding ReviewsView}" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Book Title -->
                        <DataGridTemplateColumn Header="Tên sách" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BookTitle}" 
                                               VerticalAlignment="Center" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Review Date -->
                        <DataGridTextColumn Header="Ngày kiểm duyệt" Binding="{Binding Date}" Width="1.5*"/>

                        <!-- Result Badge -->
                        <DataGridTemplateColumn Header="Kết quả" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Result}" HorizontalAlignment="Left"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Admin Comment -->
                        <DataGridTextColumn Header="Nhận xét từ Ban kiểm duyệt" Binding="{Binding AdminComment}" Width="3.5*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState>
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewsView.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Border>
    </Grid>
</UserControl>
