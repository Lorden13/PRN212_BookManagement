<UserControl x:Class="BookManagement.Views.Author.AuthorProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Border Style="{StaticResource BaseCardStyle}" Padding="32" Width="600" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title -->
                    <RowDefinition Height="*"/>    <!-- Fields Area -->
                </Grid.RowDefinitions>


                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/> <!-- Visual Avatar -->
                        <ColumnDefinition Width="32"/>  <!-- Gap -->
                        <ColumnDefinition Width="*"/>   <!-- Fields -->
                    </Grid.ColumnDefinitions>

                    <!-- Left side: Visual display -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Border Width="110" Height="110" CornerRadius="55" Background="{DynamicResource PrimaryPurpleLightBrush}" BorderBrush="{DynamicResource PrimaryPurpleBrush}" BorderThickness="2" Margin="0,0,0,16">
                            <Grid>
                                <Path Data="{StaticResource IconUser}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Tác Giả Demo" Style="{StaticResource TextBlockBold}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Alice Johnson" Style="{StaticResource TextBlockMuted}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Fields Panel -->
                    <StackPanel Grid.Column="2">
                        <!-- Name -->
                        <TextBlock Text="Họ và tên tác giả *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Nhập họ tên tác giả..." 
                                 Margin="0,0,0,20"/>

                        <!-- Email -->
                        <TextBlock Text="Địa chỉ Email *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Nhập email..." 
                                 Margin="0,0,0,20"/>

                        <!-- Bio -->
                        <TextBlock Text="Tiểu sử / Giới thiệu bản thân" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Nhập tiểu sử tác giả..." 
                                 Height="80" 
                                 AcceptsReturn="True" 
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap" 
                                 Margin="0,0,0,20"/>

                        <!-- Joined Date -->
                        <TextBlock Text="Ngày tham gia hệ thống" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" 
                                 Text="{Binding JoinedDate}" 
                                 IsEnabled="False" 
                                 Margin="0,0,0,28"/>

                        <!-- Submit Button -->
                        <Button Style="{StaticResource PrimaryButton}" 
                                Command="{Binding SaveCommand}" 
                                Content="Lưu thông tin" 
                                Height="40" 
                                HorizontalAlignment="Left" 
                                Width="160"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
