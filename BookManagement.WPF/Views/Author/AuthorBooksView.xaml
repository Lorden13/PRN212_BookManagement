<UserControl x:Class="BookManagement.Views.Author.AuthorBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Filters Header -->
            <RowDefinition Height="*"/>    <!-- DataGrid List -->
        </Grid.RowDefinitions>

        <!-- Filters card -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Search input -->
                    <ColumnDefinition Width="16"/>     <!-- Gap -->
                    <ColumnDefinition Width="180"/>    <!-- Status filter -->
                    <ColumnDefinition Width="24"/>     <!-- Gap -->
                    <ColumnDefinition Width="Auto"/>   <!-- Add Button -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Tìm kiếm theo tiêu đề sách hoặc thể loại..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>

                <!-- Status Filter -->
                <ComboBox Grid.Column="2" 
                          Style="{StaticResource ModernComboBox}" 
                          ItemsSource="{Binding Statuses}" 
                          SelectedItem="{Binding SelectedStatus}"/>

                <!-- Create Book Button -->
                <Button Grid.Column="4" 
                        Style="{StaticResource PrimaryButton}" 
                        Command="{Binding CreateBookCommand}" 
                        Content="+ Đăng ký sách" 
                        Height="38" 
                        Padding="16,0"/>
            </Grid>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid ItemsSource="{Binding MyBooksView}" 
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Title -->
                        <DataGridTemplateColumn Header="Tên sách" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" 
                                               VerticalAlignment="Center" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Category -->
                        <DataGridTextColumn Header="Thể loại" Binding="{Binding Category}" Width="1.2*"/>

                        <!-- Price -->
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1*"/>

                        <!-- Status Badge -->
                        <DataGridTemplateColumn Header="Trạng thái" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Thao tác" Width="240">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="4,0">
                                        <!-- View Detail -->
                                        <Button Style="{StaticResource OutlinedButton}" 
                                                Content="Xem" 
                                                Height="28" 
                                                Padding="12,0" 
                                                Command="{Binding SelectCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"/>

                                        <!-- Edit -->
                                        <Button Style="{StaticResource SecondaryButton}" 
                                                Content="Sửa" 
                                                Height="28" 
                                                Padding="12,0" 
                                                Command="{Binding DataContext.EditBookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0"/>

                                        <!-- Delete -->
                                        <Button Style="{StaticResource DangerButton}" 
                                                Content="Xóa" 
                                                Height="28" 
                                                Padding="12,0" 
                                                Command="{Binding DataContext.DeleteBookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState>
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MyBooksView.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Border>
    </Grid>
</UserControl>
