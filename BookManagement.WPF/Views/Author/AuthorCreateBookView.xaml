<UserControl x:Class="BookManagement.Views.Author.AuthorCreateBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header Title -->
            <RowDefinition Height="*"/>    <!-- Shared Form Control -->
        </Grid.RowDefinitions>

        <controls:SectionTitle Grid.Row="0" Text="{Binding ActionText, StringFormat='{}Tác phẩm - {0}'}" Margin="0,0,0,24"/>

        <!-- Shared Book Form -->
        <controls:BookForm Grid.Row="1"/>
    </Grid>
</UserControl>
