<UserControl x:Class="BookManagement.WPF.Views.Author.ApprovalStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="Approval Status" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Track the status of your submitted books."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <!-- Stat cards -->
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource WarningBgBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="⏳" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding PendingCount}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock Text="Pending" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource SuccessBgBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding ApprovedCount}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Approved" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource DangerBgBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="❌" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding RejectedCount}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock Text="Rejected" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Search -->
            <TextBox Style="{StaticResource ModernTextBox}" Tag="Search by book title..."
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,16" MaxWidth="360" HorizontalAlignment="Left"/>

            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource SoftShadow}" Padding="20">
                <StackPanel>
                    <DataGrid ItemsSource="{Binding Items}" Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" CellStyle="{StaticResource ModernDataGridCell}"
                              Visibility="{Binding HasBooks, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="*" MinWidth="160"/>
                            <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="SUBMITTED" Binding="{Binding SubmittedDate, StringFormat='{}{0:MMM dd, yyyy}'}" Width="120"/>
                            <DataGridTemplateColumn Header="STATUS" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToBackground}}"
                                                CornerRadius="{StaticResource RadiusRound}" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" FontSize="{StaticResource FontSizeXS}" FontWeight="SemiBold"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="LATEST COMMENT" Binding="{Binding LatestComment}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel HorizontalAlignment="Center" Margin="0,48"
                                Visibility="{Binding HasBooks, Converter={StaticResource InverseBoolToVis}}">
                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceAltBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="📝" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No submissions yet" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Submit your first book to see its status here." FontSize="{StaticResource FontSizeNormal}"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
