<UserControl x:Class="BookManagement.WPF.Views.Author.EditBookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="Edit Book" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Update your book details."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource SoftShadow}"
                    Padding="32" MaxWidth="560" HorizontalAlignment="Left">
                <StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Title" FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text=" *" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                        </StackPanel>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding TitleError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="2,4,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding TitleError, Converter={StaticResource StringNullOrEmptyToVis}}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Category" FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text=" *" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                        </StackPanel>
                        <ComboBox Style="{StaticResource ModernComboBox}" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"/>
                        <TextBlock Text="{Binding CategoryError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="2,4,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding CategoryError, Converter={StaticResource StringNullOrEmptyToVis}}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Description" FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBox}" AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                 VerticalContentAlignment="Top" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding DescriptionError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="2,4,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding DescriptionError, Converter={StaticResource StringNullOrEmptyToVis}}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Price ($)" FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text=" *" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                        </StackPanel>
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding PriceError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="2,4,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding PriceError, Converter={StaticResource StringNullOrEmptyToVis}}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Manuscript PDF" FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text=" *" Foreground="{StaticResource DangerBrush}" FontSize="{StaticResource FontSizeSmall}"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="{StaticResource RadiusMedium}" Padding="12,8">
                                <TextBlock Text="{Binding PdfPath, FallbackValue='No file selected', TargetNullValue='No file selected'}"
                                           FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Content="Choose PDF" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding SelectPdfCommand}" Padding="16,8"/>
                        </Grid>
                        <TextBlock Text="{Binding PdfError}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="{StaticResource FontSizeSmall}" Margin="2,4,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding PdfError, Converter={StaticResource StringNullOrEmptyToVis}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save Changes" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Padding="24,11" Margin="0,0,10,0"/>
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Padding="24,11"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
