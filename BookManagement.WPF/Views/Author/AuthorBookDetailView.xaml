<UserControl x:Class="BookManagement.Views.Author.AuthorBookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="*"/>    <!-- Form content -->
        </Grid.RowDefinitions>

        <controls:SectionTitle Grid.Row="0" x:Name="txtSectionTitle" Text="Chỉnh sửa chi tiết tác phẩm" Margin="0,0,0,24"/>

        <!-- Form Layout with ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Style="{StaticResource BaseCardStyle}" Padding="32" Width="700" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,24">
                <StackPanel>
                    
                    <!-- Row 1: Book ID & Created At (Readonly) -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Book ID -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã số sách (Readonly)" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtBookId" Style="{StaticResource ModernTextBox}" 
                                     IsReadOnly="True" Background="#F3F4F6" Foreground="#6B7280"/>
                        </StackPanel>

                        <!-- Created At -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ngày đăng ký (Readonly)" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtCreatedAt" Style="{StaticResource ModernTextBox}" 
                                     IsReadOnly="True" Background="#F3F4F6" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 1.5: Author & Status (Readonly) -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Author -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tác giả (Readonly)" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtAuthor" Style="{StaticResource ModernTextBox}" 
                                     IsReadOnly="True" Background="#F3F4F6" Foreground="#6B7280"/>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Trạng thái hiện tại (Readonly)" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtStatus" Style="{StaticResource ModernTextBox}" 
                                     IsReadOnly="True" Background="#F3F4F6" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Title (Editable or Readonly) -->
                    <TextBlock Text="Tiêu đề tác phẩm *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBox}" 
                             Tag="Nhập tiêu đề tác phẩm..." 
                             Margin="0,0,0,20"/>

                    <!-- Row 3: Category, Price & Stock -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <!-- Category -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Thể loại *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="cbCategory" Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Programming"/>
                                <ComboBoxItem Content="Technology"/>
                                <ComboBoxItem Content="Science"/>
                                <ComboBoxItem Content="Business"/>
                                <ComboBoxItem Content="Novel"/>
                                <ComboBoxItem Content="Education"/>
                                <ComboBoxItem Content="History"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Price -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giá bán (USD) *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtPrice" Style="{StaticResource ModernTextBox}" 
                                     Tag="0.00"/>
                        </StackPanel>

                        <!-- Stock -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Số lượng tồn kho *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtStock" Style="{StaticResource ModernTextBox}" 
                                     Tag="10"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 4: Description -->
                    <TextBlock Text="Mô tả tóm tắt *" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtDescription" Style="{StaticResource ModernTextBox}" 
                             Tag="Nhập mô tả chi tiết của sách..." 
                             Height="150" 
                             AcceptsReturn="True" 
                             VerticalContentAlignment="Top"
                             TextWrapping="Wrap" 
                             Margin="0,0,0,28"/>

                    <!-- Review History (Lịch sử kiểm duyệt) -->
                    <Border x:Name="panelReviewHistory" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Lịch sử kiểm duyệt" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="lstReviewHistory">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <controls:StatusBadge Grid.Column="0" Content="{Binding Result}" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="2" Text="{Binding AdminComment}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Date}" Style="{StaticResource TextBlockMuted}" FontSize="11" VerticalAlignment="Top" Margin="12,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Comment Form (Admin only) -->
                    <StackPanel x:Name="panelFeedback" Margin="0,0,0,24">
                        <TextBlock Text="Nhận xét &amp; Đánh giá kiểm duyệt:" Style="{StaticResource TextBlockSmallHeader}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtFeedback" Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Tag="Nhập nhận xét phê duyệt hoặc lý do từ chối..."/>
                    </StackPanel>

                    <!-- Author Action Buttons -->
                    <StackPanel x:Name="panelAuthorButtons" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Cancel -->
                        <Button Style="{StaticResource SecondaryButton}" 
                                Content="Hủy bỏ thay đổi" 
                                Width="120" 
                                Height="40"
                                Click="BtnCancel_Click"
                                Margin="0,0,12,0"/>

                        <!-- Save -->
                        <Button Style="{StaticResource PrimaryButton}" 
                                Content="Lưu thay đổi" 
                                Width="160" 
                                Height="40"
                                Click="BtnSave_Click"/>
                    </StackPanel>

                    <!-- Admin Action Buttons -->
                    <StackPanel x:Name="panelAdminButtons" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Back -->
                        <Button Style="{StaticResource SecondaryButton}" 
                                Content="Quay lại" 
                                Width="100" 
                                Height="40"
                                Click="BtnCancel_Click"
                                Margin="0,0,12,0"/>

                        <!-- Reject -->
                        <Button x:Name="btnReject" Style="{StaticResource DangerButton}" 
                                Content="Từ chối" 
                                Width="120" 
                                Height="40"
                                Click="BtnReject_Click"
                                Margin="0,0,12,0"/>

                        <!-- Approve -->
                        <Button x:Name="btnApprove" Style="{StaticResource SuccessButton}" 
                                Content="Phê duyệt" 
                                Width="140" 
                                Height="40"
                                Click="BtnApprove_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
