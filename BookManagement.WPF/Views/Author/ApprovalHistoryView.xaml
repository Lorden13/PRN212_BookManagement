<UserControl x:Class="BookManagement.WPF.Views.Author.ApprovalHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="Approval History" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="View your past approval decisions."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource SoftShadow}" Padding="20">
                <StackPanel>
                    <DataGrid ItemsSource="{Binding Records}" Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" CellStyle="{StaticResource ModernDataGridCell}"
                              Visibility="{Binding HasRecords, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="BOOK" Binding="{Binding BookTitle}" Width="*" MinWidth="180"/>
                            <DataGridTemplateColumn Header="DECISION" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Decision, Converter={StaticResource StatusToBackground}}"
                                                CornerRadius="{StaticResource RadiusRound}" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Decision}" FontSize="{StaticResource FontSizeXS}" FontWeight="SemiBold"
                                                       Foreground="{Binding Decision, Converter={StaticResource StatusToBrush}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="REVIEWED BY" Binding="{Binding ReviewedBy}" Width="130"/>
                            <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat='{}{0:MMM dd, yyyy}'}" Width="120"/>
                            <DataGridTextColumn Header="REASON" Binding="{Binding RejectionReason}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel HorizontalAlignment="Center" Margin="0,48"
                                Visibility="{Binding HasRecords, Converter={StaticResource InverseBoolToVis}}">
                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceAltBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No approval history" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Your approval records will appear here." FontSize="{StaticResource FontSizeNormal}"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
