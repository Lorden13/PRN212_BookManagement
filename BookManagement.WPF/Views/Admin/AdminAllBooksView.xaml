<UserControl x:Class="BookManagement.Views.Admin.AdminAllBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/> <!-- Category Filter -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/> <!-- Status Filter -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Tìm kiếm theo tên sách, tác giả..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>

                <!-- Category Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Thể loại:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="150" Style="{StaticResource ModernComboBox}"/>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Width="150" Style="{StaticResource ModernComboBox}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid of Books -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid ItemsSource="{Binding BooksView}" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Cover Placeholder -->
                        <DataGridTemplateColumn Header="Bìa sách" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="45" Height="60" CornerRadius="4" Background="{DynamicResource PrimaryPurpleLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Title -->
                        <DataGridTemplateColumn Header="Tác phẩm" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Author -->
                        <DataGridTextColumn Header="Tác giả" Binding="{Binding Author}" Width="1.8*"/>

                        <!-- Category -->
                        <DataGridTextColumn Header="Thể loại" Binding="{Binding Category}" Width="1.5*"/>

                        <!-- Price -->
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1.2*"/>

                      

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Thao tác" Width="240">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource OutlinedButton}" Content="Chi tiết" Height="28" Padding="12,0" Margin="0,0,8,0"
                                                Command="{Binding DataContext.ViewCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource OutlinedButton}" Content="Sửa" Height="28" Padding="12,0" Margin="0,0,8,0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource OutlinedButton}" Content="Xóa" Height="28" Padding="12,0" Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
               
            </Grid>
        </Border>
    </Grid>
</UserControl>
