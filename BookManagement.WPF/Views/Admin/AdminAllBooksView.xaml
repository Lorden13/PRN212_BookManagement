<UserControl x:Class="BookManagement.Views.Admin.AdminAllBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/> <!-- Category Filter -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/> <!-- Status Filter -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                             TextChanged="FilterInput_Changed"
                             Tag="Tìm kiếm theo tên sách, tác giả..."/>
                    <Path Data="{StaticResource IconSearch}" 
                           Fill="{DynamicResource TextMutedBrush}" 
                           Width="16" Height="16" Stretch="Uniform" 
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                           IsHitTestVisible="False"/>
                </Grid>

                <!-- Category Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Thể loại:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox x:Name="cbCategory" Width="150" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterInput_Changed"/>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox x:Name="cbStatus" Width="150" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterInput_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid of Books -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid x:Name="dgBooks" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Cover Placeholder -->
                        <DataGridTemplateColumn Header="Bìa sách" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="45" Height="60" CornerRadius="4" Background="{DynamicResource PrimaryPurpleLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Title -->
                        <DataGridTemplateColumn Header="Tác phẩm" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Author -->
                        <DataGridTextColumn Header="Tác giả" Binding="{Binding Author}" Width="1.5*"/>

                        <!-- Category -->
                        <DataGridTextColumn Header="Thể loại" Binding="{Binding Category}" Width="1.2*"/>

                        <!-- Price -->
                        <DataGridTextColumn Header="Giá bán" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1*"/>

                        <!-- Status Badge -->
                        <DataGridTemplateColumn Header="Trạng thái" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Created Date -->
                        <DataGridTextColumn Header="Ngày đăng ký" Binding="{Binding SubmittedDate}" Width="1.5*"/>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Thao tác" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource OutlinedButton}" Content="Chi tiết" Height="28" Padding="12,0" Margin="0,0,8,0"
                                                Click="BtnViewDetail_Click"/>
                                        <Button Style="{StaticResource OutlinedButton}" Content="Sửa" Height="28" Padding="12,0" Margin="0,0,8,0"
                                                Click="BtnEdit_Click"/>
                                        <Button Style="{StaticResource OutlinedButton}" Content="Xóa" Height="28" Padding="12,0" Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}"
                                                Click="BtnDelete_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState x:Name="emptyState" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
