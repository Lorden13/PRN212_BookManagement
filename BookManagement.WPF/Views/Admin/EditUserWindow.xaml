<Window x:Class="BookManagement.Views.Admin.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Chỉnh sửa người dùng"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8F9FB">
    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Chỉnh sửa người dùng" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Role, StringFormat='Vai trò: {0}'}" Style="{StaticResource TextBlockMuted}" Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Text="Họ tên" Style="{StaticResource TextBlockNormal}" Margin="0,0,0,6"/>
            <TextBox Style="{StaticResource ModernTextBox}" Height="40"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Email -->
            <TextBlock Text="Email" Style="{StaticResource TextBlockNormal}" Margin="0,16,0,6"/>
            <TextBox Style="{StaticResource ModernTextBox}" Height="40"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Phone -->
            <TextBlock Text="Số điện thoại" Style="{StaticResource TextBlockNormal}" Margin="0,16,0,6"/>
            <TextBox Style="{StaticResource ModernTextBox}" Height="40"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Address -->
            <TextBlock Text="Địa chỉ" Style="{StaticResource TextBlockNormal}" Margin="0,16,0,6"/>
            <TextBox Style="{StaticResource ModernTextBox}" Height="40"
                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Status -->
            <TextBlock Text="Trạng thái" Style="{StaticResource TextBlockNormal}" Margin="0,16,0,6"/>
            <ComboBox Style="{StaticResource ModernComboBox}" Height="40"
                      ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                <Button Content="Hủy" Style="{StaticResource OutlinedButton}" Height="40" Padding="20,0"
                        Margin="0,0,12,0" Command="{Binding CancelCommand}"/>
                <Button Content="Lưu" Style="{StaticResource PrimaryButton}" Height="40" Padding="24,0"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
