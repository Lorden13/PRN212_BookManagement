<UserControl x:Class="BookManagement.Views.Admin.AdminUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/> <!-- Role Filter -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/> <!-- Status Filter -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/> <!-- Refresh -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                             TextChanged="FilterInput_Changed"
                             Tag="Tìm kiếm theo tên, email..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>

                <!-- Role Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Vai trò:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox x:Name="cbRole" Width="150" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterInput_Changed"/>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox x:Name="cbStatus" Width="150" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterInput_Changed"/>
                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="6" Style="{StaticResource OutlinedButton}" Click="BtnRefresh_Click" Content="Làm mới" Height="36" Padding="16,0"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid x:Name="dgUsers" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Avatar & Name -->
                        <DataGridTemplateColumn Header="Người dùng" Width="2.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource PrimaryPurpleBrush}" BorderBrush="{DynamicResource PrimaryPurpleActiveBrush}" BorderThickness="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name[0]}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource MainFontFamily}"/>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Email}" Style="{StaticResource TextBlockMuted}" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Role -->
                        <DataGridTemplateColumn Header="Vai trò" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Role}" Style="{StaticResource TextBlockNormal}" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryPurpleBrush}" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Phone -->
                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="1.5*"/>

                        <!-- Status Badge -->
                        <DataGridTemplateColumn Header="Trạng thái" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Thao tác" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource OutlinedButton}" Content="Chi tiết" Height="28" Padding="12,0" Margin="0,0,8,0"
                                                Click="BtnViewDetail_Click"/>
                                        <Button Style="{StaticResource OutlinedButton}" Content="Sửa" Height="28" Padding="12,0"
                                                Click="BtnEditUser_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState x:Name="emptyState" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
