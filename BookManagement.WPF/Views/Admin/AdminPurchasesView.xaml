<UserControl x:Class="BookManagement.WPF.Views.Admin.AdminPurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="Purchases" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Overview of all reader transactions."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <!-- Stat cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource PrimaryLightBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="💰" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalRevenue, StringFormat='{}${0:N2}'}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Total Revenue" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource PrimaryLightBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="🧾" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalTransactions}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Total Transactions" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource SuccessBgBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CompletedCount}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Completed" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="20,18">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="{StaticResource RadiusMedium}"
                                Background="{StaticResource DangerBgBrush}" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="❌" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CancelledCount}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock Text="Cancelled" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource SoftShadow}" Padding="20">
                <StackPanel>
                    <DataGrid ItemsSource="{Binding Purchases}" Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" CellStyle="{StaticResource ModernDataGridCell}"
                              Visibility="{Binding HasPurchases, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="READER" Binding="{Binding ReaderName}" Width="150"/>
                            <DataGridTextColumn Header="BOOK" Binding="{Binding BookTitle}" Width="*" MinWidth="180"/>
                            <DataGridTextColumn Header="PRICE" Binding="{Binding Price, StringFormat='{}${0:N2}'}" Width="90"/>
                            <DataGridTextColumn Header="DATE" Binding="{Binding PurchaseDate, StringFormat='{}{0:MMM dd, yyyy}'}" Width="120"/>
                            <DataGridTemplateColumn Header="STATUS" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToBackground}}"
                                                CornerRadius="{StaticResource RadiusRound}" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" FontSize="{StaticResource FontSizeXS}" FontWeight="SemiBold"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel HorizontalAlignment="Center" Margin="0,48"
                                Visibility="{Binding HasPurchases, Converter={StaticResource InverseBoolToVis}}">
                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceAltBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="🧾" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No purchases yet" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Reader transactions will appear here." FontSize="{StaticResource FontSizeNormal}"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
