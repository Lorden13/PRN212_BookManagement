<UserControl x:Class="BookManagement.Views.Admin.AdminBookReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Back Button Toolbar -->
                <RowDefinition Height="*"/>    <!-- Detail & Comments Workspace -->
            </Grid.RowDefinitions>

            <!-- Back Toolbar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Button Style="{StaticResource OutlinedButton}" Content="← Quay lại kiểm duyệt" Height="36" HorizontalAlignment="Left" Command="{Binding BackCommand}"/>
            </Grid>

            <!-- Workspace Card -->
            <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/> <!-- Cover -->
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>   <!-- Info & Form -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: Large Cover -->
                    <StackPanel Grid.Column="0">
                        <Border Height="280" CornerRadius="8" Background="{DynamicResource PrimaryPurpleLightBrush}">
                            <Grid>
                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="BÌA SÁCH CHƯA ĐĂNG TẢI" Style="{StaticResource TextBlockMuted}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                            </Grid>
                        </Border>
                        <controls:StatusBadge Content="{Binding Book.Status}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Right: Info & Actions -->
                    <StackPanel Grid.Column="2">
                        <!-- Book Meta Info -->
                        <TextBlock Text="{Binding Book.Title}" Style="{StaticResource TextBlockBold}" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Book.Author, StringFormat='Tác giả: {0}'}" Style="{StaticResource TextBlockNormal}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{Binding Book.Category}" Style="{StaticResource TextBlockMuted}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding Book.Price, StringFormat='Giá đề xuất: ${0:F2}'}" Style="{StaticResource TextBlockBold}" Foreground="{DynamicResource PrimaryPurpleBrush}"/>
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock Text="Mô tả tóm tắt tác phẩm:" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Book.Description}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,24"/>

                        <!-- Review History -->
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Lịch sử kiểm duyệt" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding ReviewHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9FAFB" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <controls:StatusBadge Grid.Column="0" Content="{Binding Result}" VerticalAlignment="Top"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding AdminComment}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Date}" Style="{StaticResource TextBlockMuted}" FontSize="11" VerticalAlignment="Top" Margin="12,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Comment Form -->
                        <TextBlock Text="Nhận xét &amp; Đánh giá kiểm duyệt:" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20"
                                 Text="{Binding AdminComment, UpdateSourceTrigger=PropertyChanged}" Tag="Nhập nhận xét phê duyệt hoặc lý do từ chối..."/>

                        <!-- Actions Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource OutlinedButton}" Content="Hủy bỏ" Height="36" Width="100" Margin="0,0,12,0" Command="{Binding BackCommand}"/>
                            <Button Style="{StaticResource DangerButton}" Content="Từ chối" Height="36" Width="120" Margin="0,0,12,0" Command="{Binding RejectCommand}"/>
                            <Button Style="{StaticResource SuccessButton}" Content="Phê duyệt" Height="36" Width="120" Command="{Binding ApproveCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
