<UserControl x:Class="BookManagement.WPF.Views.Authentication.ForgotPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                <Border Width="100" Height="100" CornerRadius="50" Margin="0,0,0,28">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.15"/>
                    </Border.Background>
                    <TextBlock Text="🔑" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Reset your password"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="26" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="We'll send you a link to&#x0a;reset your password."
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}" Foreground="#C7D2FE"
                           HorizontalAlignment="Center" TextAlignment="Center" LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="60,0,60,0" MaxWidth="380">
                <TextBlock Text="Forgot password?"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeXXLarge}" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Enter your email and we'll send you a reset link"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,36"/>

                <!-- Error -->
                <Border Background="{StaticResource DangerBgBrush}" CornerRadius="{StaticResource RadiusMedium}"
                        Padding="14,10" Margin="0,0,0,20"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontFamily="{StaticResource DefaultFont}"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource DangerBrush}"/>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email address" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,28"/>

                <Button Content="Send reset link" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SendCommand}" HorizontalAlignment="Stretch"
                        Padding="20,13" FontSize="{StaticResource FontSizeMedium}" Margin="0,0,0,20"/>

                <Button Content="← Back to sign in" Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Center" Command="{Binding NavigateToLoginCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
