<UserControl x:Class="BookManagement.WPF.Views.Authentication.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                <Border Width="100" Height="100" CornerRadius="50" Margin="0,0,0,28">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.15"/>
                    </Border.Background>
                    <TextBlock Text="✨" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Join our community"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="26" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Start sharing and discovering&#x0a;amazing books today."
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}" Foreground="#C7D2FE"
                           HorizontalAlignment="Center" TextAlignment="Center" LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- RIGHT PANEL - Form -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center" Margin="60,40,60,40" MaxWidth="380">
                <TextBlock Text="Create account"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeXXLarge}" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Fill in your details to get started"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,32"/>

                <!-- Error -->
                <Border Background="{StaticResource DangerBgBrush}" CornerRadius="{StaticResource RadiusMedium}"
                        Padding="14,10" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource DangerBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Full Name -->
                <TextBlock Text="Full Name" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Email -->
                <TextBlock Text="Email address" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Address -->
                <TextBlock Text="Address" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Phone Number -->
                <TextBlock Text="Phone Number" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock Text="Password" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}"
                             PasswordChanged="PasswordBox_PasswordChanged" Margin="0,0,0,16"/>

                <!-- Confirm Password -->
                <TextBlock Text="Confirm Password" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBox}"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged" Margin="0,0,0,20"/>

                <!-- Role -->
                <TextBlock Text="I want to join as" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" IsChecked="{Binding IsAuthorRole}" GroupName="Role">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5"
                                        CornerRadius="{StaticResource RadiusMedium}" Padding="14,12" Cursor="Hand"
                                        Background="White">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="✍️" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Author" FontFamily="{StaticResource DefaultFont}"
                                                   FontSize="{StaticResource FontSizeNormal}" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton Grid.Column="2" IsChecked="{Binding IsReaderRole}" GroupName="Role">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5"
                                        CornerRadius="{StaticResource RadiusMedium}" Padding="14,12" Cursor="Hand"
                                        Background="White">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📖" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Reader" FontFamily="{StaticResource DefaultFont}"
                                                   FontSize="{StaticResource FontSizeNormal}" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </Grid>

                <!-- Register Button -->
                <Button Content="Create account" Style="{StaticResource PrimaryButton}"
                        Command="{Binding RegisterCommand}" HorizontalAlignment="Stretch"
                        Padding="20,13" FontSize="{StaticResource FontSizeMedium}" Margin="0,0,0,20"/>

                <!-- Back to Login -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account? " FontFamily="{StaticResource DefaultFont}"
                               FontSize="{StaticResource FontSizeNormal}"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <Button Content="Sign in" Style="{StaticResource LinkButton}" FontWeight="SemiBold"
                            Command="{Binding NavigateToLoginCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
