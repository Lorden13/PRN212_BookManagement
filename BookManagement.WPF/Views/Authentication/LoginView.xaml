<UserControl x:Class="BookManagement.WPF.Views.Authentication.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════ -->
        <!-- LEFT PANEL - Illustration          -->
        <!-- ══════════════════════════════════ -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#A78BFA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
                <!-- Book illustration placeholder -->
                <Border Width="120" Height="120" CornerRadius="60" Margin="0,0,0,32">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.15"/>
                    </Border.Background>
                    <TextBlock Text="📚" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Book Management"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="28" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="System"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="28" FontWeight="Light" Foreground="#C7D2FE"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Height="2" Width="40" Background="#A78BFA" CornerRadius="1" Margin="0,0,0,20"/>

                <TextBlock Text="Manage your books, authors, and readers&#x0a;all in one place."
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}" Foreground="#C7D2FE"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           LineHeight="22"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════ -->
        <!-- RIGHT PANEL - Login Form           -->
        <!-- ══════════════════════════════════ -->
        <Grid Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="60,0,60,0" MaxWidth="380">
                <!-- Header -->
                <TextBlock Text="Welcome back"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeXXLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to your account to continue"
                           FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeNormal}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,36"/>

                <!-- Error Message -->
                <Border Background="{StaticResource DangerBgBrush}"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="14,10" Margin="0,0,0,20"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource DangerBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email address" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20"/>

                <!-- Password -->
                <TextBlock Text="Password" FontFamily="{StaticResource DefaultFont}"
                           FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}"
                             
                             Margin="0,0,0,8"/>

                <!-- Forgot Password -->
                <Button Content="Forgot your password?"
                        Style="{StaticResource LinkButton}"
                        HorizontalAlignment="Right"
                        FontSize="{StaticResource FontSizeSmall}"
                        Command="{Binding NavigateToForgotPasswordCommand}"
                        Margin="0,0,0,28"/>

                <!-- Login Button -->
                <Button Content="Sign in"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="20,13"
                        FontSize="{StaticResource FontSizeMedium}"
                        Margin="0,0,0,20"/>

                <!-- Divider -->
                <Grid Margin="0,0,0,20">
                    <Border Height="1" Background="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="or" Background="White" Padding="12,0"
                               FontFamily="{StaticResource DefaultFont}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- Register Link -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Don't have an account? "
                               FontFamily="{StaticResource DefaultFont}"
                               FontSize="{StaticResource FontSizeNormal}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Create account"
                            Style="{StaticResource LinkButton}"
                            FontWeight="SemiBold"
                            Command="{Binding NavigateToRegisterCommand}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
