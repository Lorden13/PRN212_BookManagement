<UserControl x:Class="BookManagement.Views.Reader.ReaderBookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/> <!-- Main detail area -->
            <ColumnDefinition Width="32"/>  <!-- Gap -->
            <ColumnDefinition Width="280"/> <!-- Recommended Panel -->
        </Grid.ColumnDefinitions>

        <!-- Left Column: Main Detail & Reviews Scroll Area -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                
                <!-- Back Button -->
                <Button Style="{StaticResource OutlinedButton}" 
                        Click="BtnBack_Click" 
                        Content="← Quay lại danh sách" 
                        HorizontalAlignment="Left"
                        Height="36" 
                        Padding="16,0" 
                        Margin="0,0,0,20"/>

                <!-- Main Info Card -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/> <!-- Cover -->
                            <ColumnDefinition Width="24"/>  <!-- Gap -->
                            <ColumnDefinition Width="*"/>   <!-- Text Details -->
                        </Grid.ColumnDefinitions>

                        <!-- Cover Image -->
                        <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource PrimaryPurpleLightBrush}" Height="210">
                            <Grid>
                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="COVER IMAGE" Foreground="{DynamicResource PrimaryPurpleBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                            </Grid>
                        </Border>

                        <!-- Details -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <controls:StatusBadge x:Name="txtCategory" Content="Category" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtTitle" Text="Book Title" Style="{StaticResource TextBlockMediumHeader}" FontSize="24" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtAuthor" Text="Tác giả: Name" Style="{StaticResource TextBlockNormal}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Rating -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" Fill="#FBBF24" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtRating" Text="0.0 / 5.0" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Price -->
                            <TextBlock x:Name="txtPrice" Text="$0.00" Foreground="{DynamicResource PrimaryPurpleBrush}" FontSize="28" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtStock" Text="Còn 10 cuốn" FontSize="13" FontWeight="SemiBold" Foreground="#16A34A" Margin="0,0,0,16"/>

                            <!-- Action Buttons -->
                            <Grid x:Name="actionButtonsPanel" HorizontalAlignment="Left">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <!--<Button x:Name="btnBuy" Grid.Row="0" Grid.Column="0"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="Mua ngay"
                                        Click="BtnBuy_Click"
                                        Height="40"/>-->
                                <Button x:Name="btnAddToCart" Grid.Row="0" Grid.Column="2"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnAddToCart_Click"
                                        Content="Thêm vào giỏ"
                                        Height="40"/>
                                <Button Grid.Row="0" Grid.Column="4"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnFavorite_Click"
                                        Content="Yêu thích"
                                        Height="40"/>
                                <Button Grid.Row="1" Grid.Column="0"
                                        Style="{StaticResource OutlinedButton}"
                                        Click="BtnShowReview_Click"
                                        Content="Đánh giá"
                                        Height="36"
                                        Margin="0,10,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="reviewEditor"
                        Style="{StaticResource BaseCardStyle}"
                        Padding="24"
                        Margin="0,0,0,24"
                        Visibility="Collapsed">
                    <StackPanel>
                        <controls:SectionTitle Text="Đánh giá sách" Margin="0,0,0,12"/>
                        <ComboBox x:Name="cbReviewRating"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="180"
                                  HorizontalAlignment="Left"
                                  SelectedIndex="4">
                            <ComboBoxItem Content="1 sao" Tag="1"/>
                            <ComboBoxItem Content="2 sao" Tag="2"/>
                            <ComboBoxItem Content="3 sao" Tag="3"/>
                            <ComboBoxItem Content="4 sao" Tag="4"/>
                            <ComboBoxItem Content="5 sao" Tag="5"/>
                        </ComboBox>
                        <TextBox x:Name="txtReviewComment"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Nhập nhận xét của bạn..."
                                 MaxLength="1000"
                                 MinHeight="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Margin="0,12,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Gửi đánh giá"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,10,0"
                                    Click="BtnSubmitReview_Click"/>
                            <Button Content="Hủy"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="80"
                                    Height="36"
                                    Click="BtnCancelReview_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Description Card -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <controls:SectionTitle Text="Giới thiệu sách" Margin="0,0,0,12"/>
                        <TextBlock x:Name="txtDescription" Text="Book Description" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- Reviews Section -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24">
                    <StackPanel>
                        <controls:SectionTitle Text="Đánh giá từ độc giả" Margin="0,0,0,16"/>

                        <!-- Reviews List -->
                        <ItemsControl x:Name="icReviews">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Reviewer Name & Date -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding ReaderName}" Style="{StaticResource TextBlockBold}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Date}" Style="{StaticResource TextBlockMuted}"/>
                                            </Grid>

                                            <!-- Rating -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBlock Text="★" Foreground="#FBBF24" FontSize="16"/>
                                                <TextBlock Text="{Binding Rating, StringFormat=' {0}/5'}" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- Comment text -->
                                            <TextBlock Grid.Row="2" Text="{Binding Comment}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State if no reviews -->
                        <controls:EmptyState x:Name="emptyReviewsState" Margin="0,10,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Right Column: Recommended Books Panel -->
        <Border Grid.Column="2" Style="{StaticResource BaseCardStyle}" Padding="16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Sách đề xuất" Style="{StaticResource TextBlockBold}" FontSize="16" Margin="0,0,0,16"/>
                
                <ItemsControl x:Name="icRecommendedBooks">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:BookCard Cursor="Hand" MouseDown="RecommendedBookCard_MouseDown" Margin="0,0,0,12"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
