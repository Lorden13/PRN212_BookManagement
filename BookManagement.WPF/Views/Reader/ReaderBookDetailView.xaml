<UserControl x:Class="BookManagement.Views.Reader.ReaderBookDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/> <!-- Main detail area -->
            <ColumnDefinition Width="32"/>  <!-- Gap -->
            <ColumnDefinition Width="280"/> <!-- Recommended Panel -->
        </Grid.ColumnDefinitions>

        <!-- Left Column: Main Detail & Reviews Scroll Area -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                
                <!-- Back Button -->
                <Button Style="{StaticResource OutlinedButton}" 
                        Command="{Binding BackCommand}" 
                        Content="← Quay lại danh sách" 
                        HorizontalAlignment="Left"
                        Height="36" 
                        Padding="16,0" 
                        Margin="0,0,0,20"/>

                <!-- Main Info Card -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/> <!-- Cover -->
                            <ColumnDefinition Width="24"/>  <!-- Gap -->
                            <ColumnDefinition Width="*"/>   <!-- Text Details -->
                        </Grid.ColumnDefinitions>

                        <!-- Cover Image -->
                        <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource PrimaryPurpleLightBrush}" Height="210">
                            <Grid>
                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="COVER IMAGE" Foreground="{DynamicResource PrimaryPurpleBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                            </Grid>
                        </Border>

                        <!-- Details -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <controls:StatusBadge Content="{Binding Book.Category}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Book.Title}" Style="{StaticResource TextBlockMediumHeader}" FontSize="24" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Book.Author, StringFormat='Tác giả: {0}'}" Style="{StaticResource TextBlockNormal}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <!-- Rating -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" Fill="#FBBF24" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Book.Rating, StringFormat='{}{0:F1} / 5.0'}" Style="{StaticResource TextBlockBold}" FontSize="14" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Price -->
                            <TextBlock Text="{Binding Book.Price, StringFormat='${0:F2}'}" Foreground="{DynamicResource PrimaryPurpleBrush}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}" 
                                        Command="{Binding BuyCommand}" 
                                        Content="Mua ngay" 
                                        Width="150" 
                                        Height="40" 
                                        Margin="0,0,12,0"/>
                                <Button Style="{StaticResource SecondaryButton}" 
                                        Command="{Binding AddToFavoritesCommand}" 
                                        Content="Yêu thích" 
                                        Width="150" 
                                        Height="40"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Description Card -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <controls:SectionTitle Text="Giới thiệu sách" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding Book.Description}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- Reviews Section -->
                <Border Style="{StaticResource BaseCardStyle}" Padding="24">
                    <StackPanel>
                        <controls:SectionTitle Text="Đánh giá từ độc giả" Margin="0,0,0,16"/>

                        <!-- Reviews List -->
                        <ItemsControl ItemsSource="{Binding Reviews}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Reviewer Name & Date -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Người dùng hệ thống" Style="{StaticResource TextBlockBold}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Date}" Style="{StaticResource TextBlockMuted}"/>
                                            </Grid>

                                            <!-- Result Badge -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,8">
                                                <controls:StatusBadge Content="{Binding Result}"/>
                                            </StackPanel>

                                            <!-- Comment text -->
                                            <TextBlock Grid.Row="2" Text="{Binding AdminComment}" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State if no reviews -->
                        <controls:EmptyState Margin="0,10,0,0">
                            <controls:EmptyState.Style>
                                <Style TargetType="controls:EmptyState">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Reviews.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:EmptyState.Style>
                        </controls:EmptyState>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Right Column: Recommended Books Panel -->
        <Border Grid.Column="2" Style="{StaticResource BaseCardStyle}" Padding="16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Sách đề xuất" Style="{StaticResource TextBlockBold}" FontSize="16" Margin="0,0,0,16"/>
                
                <ItemsControl ItemsSource="{Binding RecommendedBooks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:BookCard DataContext="{Binding}" Margin="0,0,0,12">
                                <controls:BookCard.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding SelectCommand}" 
                                                  CommandParameter="{Binding}"/>
                                </controls:BookCard.InputBindings>
                            </controls:BookCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
