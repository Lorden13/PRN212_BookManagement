<UserControl x:Class="BookManagement.WPF.Views.Reader.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="My Profile" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Manage your profile information and account security."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Profile Info -->
                <Border Grid.Column="0" Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="32">
                    <StackPanel>
                        <TextBlock Text="Personal Details" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                        <!-- Profile Alert/Message -->
                        <Border CornerRadius="{StaticResource RadiusMedium}" Padding="14,10" Margin="0,0,0,16"
                                Visibility="{Binding HasProfileMessage, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProfileMessageSuccess}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SuccessBgBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProfileMessageSuccess}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource DangerBgBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ProfileMessage}" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProfileMessageSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsProfileMessageSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Full Name -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Full Name" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Email (Disabled/Read-only) -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Email address (cannot be changed)" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Email}" IsEnabled="False" Opacity="0.6"/>
                        </StackPanel>

                        <!-- Address -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Address" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Phone Number -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Phone Number" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Button Content="Save Profile" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveProfileCommand}" HorizontalAlignment="Left" Padding="28,11"/>
                    </StackPanel>
                </Border>

                <!-- Right Column: Change Password -->
                <Border Grid.Column="2" Background="White" CornerRadius="{StaticResource RadiusLarge}"
                        Effect="{StaticResource SoftShadow}" Padding="32">
                    <StackPanel>
                        <TextBlock Text="Change Password" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                        <!-- Password Alert/Message -->
                        <Border CornerRadius="{StaticResource RadiusMedium}" Padding="14,10" Margin="0,0,0,16"
                                Visibility="{Binding HasPasswordMessage, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasswordMessageSuccess}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SuccessBgBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPasswordMessageSuccess}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource DangerBgBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding PasswordMessage}" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordMessageSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPasswordMessageSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Current Password -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Current Password" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="CurrentPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                        </StackPanel>

                        <!-- New Password -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="New Password (min 6 characters)" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="NewPasswordBox_PasswordChanged"/>
                        </StackPanel>

                        <!-- Confirm Password -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Confirm New Password" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeSmall}" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox x:Name="ConfirmNewPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="ConfirmNewPasswordBox_PasswordChanged"/>
                        </StackPanel>

                        <Button Content="Update Password" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ChangePasswordCommand}" HorizontalAlignment="Left" Padding="28,11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
