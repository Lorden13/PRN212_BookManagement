<UserControl x:Class="BookManagement.WPF.Views.Reader.FavoriteBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:BookManagement.WPF.Views.Shared"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <TextBlock Text="Favorite Books" FontFamily="{StaticResource DefaultFont}"
                       FontSize="{StaticResource FontSizeXLarge}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Your saved books collection."
                       FontFamily="{StaticResource DefaultFont}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <ItemsControl ItemsSource="{Binding FavoriteBooks}"
                          Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <shared:BookCardControl Book="{Binding}"
                            ShowViewDetails="True" ShowRemoveFavorite="True"
                            ViewDetailsCommand="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            RemoveFavoriteCommand="{Binding DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource SoftShadow}"
                    Padding="48" Visibility="{Binding HasFavorites, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource SurfaceAltBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="❤️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No favorites yet" FontSize="{StaticResource FontSizeMedium}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Browse books and add some to your favorites!" FontSize="{StaticResource FontSizeNormal}"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
