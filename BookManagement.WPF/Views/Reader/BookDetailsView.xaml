<UserControl x:Class="BookManagement.WPF.Views.Reader.BookDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24">
            <!-- Back -->
            <Button Content="← Back to Browse" Style="{StaticResource LinkButton}"
                    Command="{Binding BackCommand}" HorizontalAlignment="Left"
                    FontSize="{StaticResource FontSizeNormal}" Margin="0,0,0,20"/>

            <!-- Detail Card -->
            <Border Background="White" CornerRadius="{StaticResource RadiusLarge}" Effect="{StaticResource CardShadow}"
                    Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left - Cover -->
                    <Border Grid.Column="0" CornerRadius="12,0,0,12" MinHeight="420"
                            Background="{Binding CoverColor, Converter={StaticResource StringToBrush}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📖" FontSize="72" Opacity="0.4"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeLarge}"
                                       FontWeight="Bold" Foreground="White" Opacity="0.8"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="240"/>
                        </StackPanel>
                    </Border>

                    <!-- Right - Info -->
                    <StackPanel Grid.Column="1" Margin="36,32">
                        <!-- Category Badge -->
                        <Border Background="{StaticResource PrimaryLightBrush}"
                                CornerRadius="{StaticResource RadiusRound}"
                                Padding="12,5" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="{Binding Category}" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="{StaticResource FontSizeXS}" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="{Binding Title}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeXXLarge}" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <!-- Author -->
                        <TextBlock FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                            <Run Text="by "/>
                            <Run Text="{Binding AuthorName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>

                        <!-- Divider -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,20"/>

                        <!-- Description -->
                        <TextBlock Text="Description" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Description}" FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeNormal}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,24"/>

                        <!-- Price -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <TextBlock Text="{Binding Price}" FontFamily="{StaticResource DefaultFont}"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🛒  Buy Now" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BuyCommand}" Padding="28,12"
                                    FontSize="{StaticResource FontSizeMedium}" Margin="0,0,10,0"/>
                            <Button Content="♥  Add to Favorites" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding FavoriteCommand}" Padding="28,12"
                                    FontSize="{StaticResource FontSizeMedium}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
