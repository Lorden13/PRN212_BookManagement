<UserControl x:Class="BookManagement.Views.Reader.ReaderCartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="20" Margin="0,0,0,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Giỏ hàng" Style="{StaticResource TextBlockMediumHeader}"/>
                    <TextBlock x:Name="txtCartSummary"
                               Text="0 sách trong giỏ hàng"
                               Style="{StaticResource TextBlockMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock x:Name="txtTotal"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryPurpleBrush}"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="$0.00"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid x:Name="dgCart" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên sách" Binding="{Binding Book.Title}" Width="2*"/>
                        <DataGridTextColumn Header="Tác giả" Binding="{Binding Book.Author.AuthorNavigation.FullName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Thể loại" Binding="{Binding Book.Category}" Width="1*"/>
                        <DataGridTextColumn Header="Giá" Binding="{Binding Book.Price, StringFormat='${0:F2}'}" Width="0.8*"/>
                        <DataGridTemplateColumn Header="Số lượng" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="−" Width="28" Height="28" FontSize="14" FontWeight="Bold"
                                                Style="{StaticResource OutlinedButton}" Padding="0"
                                                Click="BtnDecrease_Click"/>
                                        <TextBlock Text="{Binding Quantity}" Width="32" TextAlignment="Center"
                                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                                        <Button Content="+" Width="28" Height="28" FontSize="14" FontWeight="Bold"
                                                Style="{StaticResource OutlinedButton}" Padding="0"
                                                Click="BtnIncrease_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Thao tác" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa"
                                            Style="{StaticResource DangerButton}"
                                            Height="30"
                                            Padding="14,0"
                                            Click="BtnRemove_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyState x:Name="emptyState" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Button x:Name="btnCheckout"
                Grid.Row="2"
                Content="Thanh toán"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Width="160"
                Height="42"
                Margin="0,20,0,0"
                Visibility="Collapsed"
                Click="BtnCheckout_Click"/>
    </Grid>
</UserControl>
