<UserControl x:Class="BookManagement.WPF.Views.Reader.PurchaseHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <TextBlock Text="Sách của tôi" FontFamily="{StaticResource MainFontFamily}"
                       FontSize="{StaticResource FontSizeHeaderMedium}" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="Danh sách những sách bạn đã mua."
                       FontFamily="{StaticResource MainFontFamily}" FontSize="{StaticResource FontSizeNormal}"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource BaseCardStyle}" Padding="20">
                <StackPanel>
                    <DataGrid x:Name="dgPurchasedBooks"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TÊN SÁCH" Binding="{Binding Book.Title}" Width="*" MinWidth="200"/>
                            <DataGridTextColumn Header="THỂ LOẠI" Binding="{Binding Book.Category}" Width="150"/>
                            <DataGridTextColumn Header="NGÀY MUA" Binding="{Binding PurchasedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                            <DataGridTemplateColumn Header="GIÁ" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Book.Price, StringFormat='${0:N2}'}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryPurpleBrush}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Xem chi tiết"
                                                Style="{StaticResource OutlinedButton}"
                                                Height="30"
                                                Padding="10,0"
                                                Click="BtnViewBook_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel x:Name="emptyPurchasedBooks" HorizontalAlignment="Center" Margin="0,48" Visibility="Collapsed">
                        <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource PrimaryPurpleLightBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="🛒" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Bạn chưa mua sách nào" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Hãy khám phá và mua cuốn sách đầu tiên." FontSize="{StaticResource FontSizeNormal}"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
