<UserControl x:Class="BookManagement.Views.Reader.ReaderHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                Padding="4"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{DynamicResource PrimaryPurpleLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#DDD6FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Welcome Section -->
                <RowDefinition Height="Auto"/> <!-- Search Panel (Full Width) -->
                <RowDefinition Height="*"/>    <!-- Main Side-by-Side Area -->
            </Grid.RowDefinitions>

            <!-- 1. Welcome Section -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="txtWelcome" Text="Welcome back!" 
                           FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" 
                           FontFamily="{DynamicResource MainFontFamily}"/>
                <TextBlock Text="Discover your next favorite book." 
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"
                           FontFamily="{DynamicResource MainFontFamily}"/>
            </StackPanel>

            <!-- 2. Search Panel: Find Your Next Read (Full Width) -->
            <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Find Your Next Read" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search text box -->
                        <Grid Grid.Column="0">
                            <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                                     Tag="Search by title, author or keyword..."/>
                            <Path Data="{StaticResource IconSearch}" 
                                  Fill="{DynamicResource TextMutedBrush}" 
                                  Width="16" Height="16" Stretch="Uniform" 
                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                                  IsHitTestVisible="False"/>
                        </Grid>
                        
                        <!-- Category ComboBox -->
                        <ComboBox x:Name="cbCategory" Grid.Column="2" 
                                  Style="{StaticResource ModernComboBox}"/>
                        
                        <!-- Search Button -->
                        <Button Grid.Column="4" 
                                Style="{StaticResource PrimaryButton}" 
                                Content="Search" 
                                Height="40"
                                Click="BtnSearch_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. Side-by-side Grid -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Left side (Popular, Recommended, Recently Purchased) -->
                    <ColumnDefinition Width="320"/>    <!-- Right side (Quick Actions) -->
                </Grid.ColumnDefinitions>

                <!-- Left Content -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    
                    <!-- Popular Books Section -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Popular Books" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource OutlinedButton}" Content="View all" Padding="12,4" Height="28" BorderThickness="0"
                                Click="BtnViewAllBooks_Click"/>
                    </Grid>
                    
                    <ItemsControl x:Name="icPopularBooks" Margin="0,0,0,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:BookCard Cursor="Hand" MouseDown="BookCard_MouseDown"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Recommended Books Section -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Recommended Books" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource OutlinedButton}" Content="View all" Padding="12,4" Height="28" BorderThickness="0"
                                Click="BtnViewAllBooks_Click"/>
                    </Grid>
                    
                    <ItemsControl x:Name="icRecommendedBooks" Margin="0,0,0,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:BookCard Cursor="Hand" MouseDown="BookCard_MouseDown"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Recently Purchased Section -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!--<TextBlock Grid.Column="0" Text="Recently Purchased" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource OutlinedButton}" Content="View all" Padding="12,4" Height="28" BorderThickness="0"
                                Click="BtnViewAllLibrary_Click"/>-->
                    </Grid>

                    <Border Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,24">
                        <Grid>
                            <DataGrid x:Name="dgRecentPurchases"
                                      Style="{StaticResource ModernDataGrid}" 
                                      AutoGenerateColumns="False" 
                                      HeadersVisibility="Column" 
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <!-- Cover -->
                                    <DataGridTemplateColumn Header="Book" Width="3*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="36" Height="48" CornerRadius="4" Background="{DynamicResource PrimaryPurpleLightBrush}" Margin="0,0,12,0" ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding CoverImagePath}" Stretch="UniformToFill" Visibility="Collapsed"/>
                                                            <Grid>
                                                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Purchase Date -->
                                    <DataGridTextColumn Header="Purchase Date" Binding="{Binding PurchaseDate}" Width="2*"/>

                                    <!-- Price -->
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1.5*"/>

                                    <!-- Status -->
                                    <DataGridTemplateColumn Header="Status" Width="1.5*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Content (Quick Actions) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Border Style="{StaticResource BaseCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            
                            <!-- Browse Books -->
                            <Button Style="{StaticResource QuickActionButtonStyle}" Click="BtnViewAllBooks_Click" Margin="0,0,0,12" Height="60">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource PrimaryPurpleLightBrush}">
                                        <Path Data="{StaticResource IconBooks}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Browse Books" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Explore all books" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Path Grid.Column="2" Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <!-- My Library --><!--
                            <Button Style="{StaticResource QuickActionButtonStyle}" Click="BtnViewAllLibrary_Click" Margin="0,0,0,12" Height="60">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource PrimaryPurpleLightBrush}">
                                        <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="My Library" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="View your library" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Path Grid.Column="2" Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>-->

                            <!-- Profile -->
                            <Button Style="{StaticResource QuickActionButtonStyle}" Click="BtnViewProfile_Click" Margin="0,0,0,12" Height="60">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource PrimaryPurpleLightBrush}">
                                        <Path Data="{StaticResource IconUser}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Profile" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Update your profile" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Path Grid.Column="2" Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextMutedBrush}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
