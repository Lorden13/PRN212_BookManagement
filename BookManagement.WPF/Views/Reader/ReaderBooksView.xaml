<UserControl x:Class="BookManagement.Views.Reader.ReaderBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Filters Card -->
            <RowDefinition Height="*"/>    <!-- Catalog Card Grid & Pagination -->
        </Grid.RowDefinitions>

        <!-- Filters Section -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- Search & Price -->
                    <ColumnDefinition Width="16"/>     <!-- Gap -->
                    <ColumnDefinition Width="200"/>    <!-- Category & Sort -->
                    <ColumnDefinition Width="16"/>     <!-- Gap -->
                    <ColumnDefinition Width="200"/>    <!-- Clear -->
                </Grid.ColumnDefinitions>

                <!-- Row 0: Search Box and Category -->
                <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                             TextChanged="FilterInput_Changed"
                             Tag="Search by title or author..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>

                <ComboBox x:Name="cbCategory" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                          Style="{StaticResource ModernComboBox}" 
                          SelectionChanged="FilterInput_Changed"/>

                <!-- Row 1: Max Price input, Sort ComboBox, Clear Button -->
                <Grid Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Max Price:"
                               Width="80"
                               Style="{StaticResource TextBlockNormal}"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="txtMaxPrice" Grid.Column="1" VerticalAlignment="Center"
                             Style="{StaticResource ModernTextBox}"
                             Tag="Max price..."
                             TextChanged="FilterInput_Changed"/>
                </Grid>

                <ComboBox x:Name="cbSort" Grid.Row="1" Grid.Column="2" Margin="0,12,0,0" VerticalAlignment="Center"
                          Style="{StaticResource ModernComboBox}" 
                          SelectionChanged="FilterInput_Changed"/>

                <Button Grid.Row="1" Grid.Column="4" Margin="0,12,0,0" VerticalAlignment="Center"
                        Style="{StaticResource SecondaryButton}" 
                        Content="Clear Filters" 
                        Click="BtnClearFilters_Click"/>
            </Grid>
        </Border>

        <!-- Catalog Card Grid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="icBooks">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:BookCard Cursor="Hand" MouseDown="BookCard_MouseDown"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State if no books found -->
                    <controls:EmptyState x:Name="emptyState" Margin="0,40,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Pagination -->
            <controls:Pagination x:Name="pagination" Grid.Row="1" 
                                 PrevClick="BtnPrevPage_Click"
                                 NextClick="BtnNextPage_Click"/>
        </Grid>
    </Grid>
</UserControl>
