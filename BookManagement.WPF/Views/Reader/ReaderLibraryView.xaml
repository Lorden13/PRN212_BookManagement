<UserControl x:Class="BookManagement.Views.Reader.ReaderLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search bar -->
            <RowDefinition Height="*"/>    <!-- DataGrid Card -->
        </Grid.RowDefinitions>

        <!-- Search Bar Header -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid Grid.Column="0" Width="320" HorizontalAlignment="Left">
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Search by title, author or status..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Purchases DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid ItemsSource="{Binding LibraryItemsView}" 
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <!-- Cover -->
                        <DataGridTemplateColumn Header="Cover" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                     <Border Width="45" Height="60" CornerRadius="6" Background="{DynamicResource PrimaryPurpleLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" ClipToBounds="True">
                                         <Grid>
                                             <Image Source="{Binding CoverImagePath}" Stretch="UniformToFill" Visibility="Collapsed"/>
                                             <Grid>
                                                 <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Grid>
                                         </Grid>
                                     </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Title & Author -->
                        <DataGridTemplateColumn Header="Title" Width="3.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding BookTitle}" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Author}" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Purchase Date -->
                        <DataGridTextColumn Header="Purchase Date" Binding="{Binding PurchaseDate}" Width="1.5*"/>

                        <!-- Status Badge -->
                        <DataGridTemplateColumn Header="Status" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Read Button -->
                        <DataGridTemplateColumn Header="Read" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OutlinedButton}" 
                                            Content="Read" 
                                            Height="28" 
                                            Padding="12,0" 
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ReadCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState>
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LibraryItemsView.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Border>
    </Grid>
</UserControl>
