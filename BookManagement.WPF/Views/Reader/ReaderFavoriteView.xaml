<UserControl x:Class="BookManagement.Views.Reader.ReaderFavoriteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Search Header -->
            <RowDefinition Height="*"/>    <!-- DataGrid Container -->
        </Grid.RowDefinitions>

        <!-- Search Favorite Header -->
        <Border Grid.Row="0" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                    <TextBox x:Name="txtSearch" Style="{StaticResource ModernTextBox}" 
                             TextChanged="txtSearch_TextChanged"
                             Tag="Tìm kiếm trong danh sách yêu thích..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>
            </Grid>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid x:Name="dgFavorites"
                           Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Title -->
                        <DataGridTemplateColumn Header="Tên sách" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" 
                                               VerticalAlignment="Center" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Author -->
                        <DataGridTextColumn Header="Tác giả" Binding="{Binding Author}" Width="1.5*"/>

                        <!-- Category -->
                        <DataGridTemplateColumn Header="Thể loại" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Category}" HorizontalAlignment="Left"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Price -->
                        <DataGridTextColumn Header="Giá sách" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1*"/>

                        <!-- Rating -->
                        <DataGridTemplateColumn Header="Đánh giá" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" 
                                              Fill="#FBBF24" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Rating, StringFormat=' {0:F1}'}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Action Buttons -->
                        <DataGridTemplateColumn Header="Thao tác" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="4,0">
                                        <!-- Buy button -->
                                        <Button Style="{StaticResource PrimaryButton}" 
                                                Content="Mua" 
                                                Height="28" 
                                                Padding="12,0" 
                                                Click="BtnBuy_Click"
                                                Margin="0,0,8,0"/>

                                        <!-- Remove button -->
                                        <Button Style="{StaticResource DangerButton}" 
                                                Content="Xóa" 
                                                Height="28" 
                                                Padding="12,0"
                                                Click="BtnRemove_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState x:Name="emptyState" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
