<UserControl x:Class="BookManagement.Controls.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="350"
             Visibility="{Binding RelativeSource={RelativeSource Self}, Path=IsOpen, Converter={StaticResource BoolToVisConverter}}">
    
    <Border Background="White"
            CornerRadius="8"
            Width="350"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="20"
            Padding="16"
            BorderThickness="4,1,1,1"
            BorderBrush="{Binding RelativeSource={RelativeSource AncestorType=local:NotificationControl}, Path=Status, Converter={StaticResource StatusToBrushConv}}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                              ShadowDepth="2" 
                              Opacity="0.1" 
                              Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Status Icon -->
                <ColumnDefinition Width="*"/>      <!-- Title & Message Content -->
                <ColumnDefinition Width="Auto"/>   <!-- Close Button -->
            </Grid.ColumnDefinitions>

            <!-- Status Icon -->
            <Path Grid.Column="0" 
                  Data="{Binding RelativeSource={RelativeSource AncestorType=local:NotificationControl}, Path=Status, Converter={StaticResource StatusToIconGeomConv}}" 
                  Fill="{Binding RelativeSource={RelativeSource AncestorType=local:NotificationControl}, Path=Status, Converter={StaticResource StatusToBrushConv}}"
                  Width="18" Height="18" 
                  Stretch="Uniform" 
                  VerticalAlignment="Top" 
                  Margin="0,2,12,0"/>

            <!-- Content Area (Title & Description) -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=local:NotificationControl}, Path=Title}" 
                           Style="{StaticResource TextBlockNormal}"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,2"/>
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=local:NotificationControl}, Path=Message}" 
                           Style="{StaticResource TextBlockNormal}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Close Button -->
            <Button Grid.Column="2" 
                    Style="{StaticResource IconButton}" 
                    Width="24" Height="24" 
                    VerticalAlignment="Top"
                    Click="CloseButton_Click"
                    Margin="8,-4,-4,0">
                <Path Data="{StaticResource IconClose}" 
                      Fill="{DynamicResource TextMutedBrush}" 
                      Width="8" Height="8" 
                      Stretch="Uniform"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
