<UserControl x:Class="BookManagement.Controls.BookCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="320" d:DesignWidth="220">
    <Border Style="{StaticResource HoverCardStyle}" Width="200" Height="300" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="140"/>   <!-- Book Cover Placeholder -->
                <RowDefinition Height="Auto"/>  <!-- Category & Rating -->
                <RowDefinition Height="*"/>     <!-- Title & Author -->
                <RowDefinition Height="Auto"/>  <!-- Price & Button -->
            </Grid.RowDefinitions>

            <!-- Book Cover -->
            <Border Grid.Row="0" CornerRadius="8" Background="{DynamicResource PrimaryPurpleLightBrush}" Margin="0,0,0,12" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding CoverImagePath}" Stretch="UniformToFill" Visibility="Collapsed"/>
                    
                    <!-- Fallback placeholder (always visible) -->
                    <Grid>
                        <Path Data="{StaticResource IconBook}" 
                              Fill="{DynamicResource PrimaryPurpleBrush}" 
                              Width="40" Height="40" 
                              Stretch="Uniform" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                        <TextBlock Text="NO COVER" 
                                   Foreground="{DynamicResource PrimaryPurpleBrush}" 
                                   FontSize="10" 
                                   FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Bottom" 
                                   Margin="0,0,0,10"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Category & Status/Badge Placeholder -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Category, FallbackValue='Programming'}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           FontSize="{StaticResource FontSizeSmall}"
                           FontFamily="{DynamicResource MainFontFamily}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" 
                          Fill="#FBBF24" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Rating, FallbackValue='0.0'}" 
                               Foreground="{DynamicResource TextPrimaryBrush}" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               FontWeight="Bold" 
                               Margin="4,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="{DynamicResource MainFontFamily}"/>
                </StackPanel>
            </Grid>

            <!-- Title & Author -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="{Binding Title, FallbackValue='Clean Code'}" 
                           Style="{StaticResource TextBlockBold}" 
                           FontSize="{StaticResource FontSizeNormal}" 
                           MaxHeight="38" 
                           TextWrapping="Wrap" 
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Author, FallbackValue='Unknown Author'}" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           FontSize="{StaticResource FontSizeSmall}" 
                           Margin="0,2,0,0"
                           FontFamily="{DynamicResource MainFontFamily}"/>
            </StackPanel>

            <!-- Price and Buy Button -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{Binding Price, StringFormat='${0:F2}', FallbackValue='$0.00'}" 
                           Foreground="{DynamicResource PrimaryPurpleBrush}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource MainFontFamily}"/>
                
                <Button Grid.Column="1" 
                        Style="{StaticResource PrimaryButton}" 
                        Content="Mua" 
                        Height="32" 
                        Padding="12,0"
                        Command="{Binding DataContext.BuyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
