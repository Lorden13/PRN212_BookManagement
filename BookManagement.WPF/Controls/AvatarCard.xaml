<UserControl x:Class="BookManagement.Controls.AvatarCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
         
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Grid>
        <!-- Circle Border -->
        <Border Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:AvatarCard}}, Path=Width}"
                Height="{Binding
    RelativeSource={RelativeSource AncestorType={x:Type local:AvatarCard}},
    Path=Height}"
                CornerRadius="25"
                Background="{DynamicResource PrimaryPurpleBrush}"
                BorderBrush="#FFFFFF"
                BorderThickness="1.5"
                SnapsToDevicePixels="True">
            <Grid>
                <!-- Initial Letter -->
                <TextBlock Text="{Binding Name[0], FallbackValue='U'}" 
                           Foreground="#FFFFFF" 
                           FontWeight="Bold" 
                           FontSize="14"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource MainFontFamily}"/>
                
                <!-- Avatar image (optional) -->
                <!-- We can add an Image control, but for Phase 1 we will just use initials since it is mock only -->
            </Grid>
        </Border>
    </Grid>
</UserControl>
