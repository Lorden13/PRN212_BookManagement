<UserControl x:Class="BookManagement.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="260"
             >
    <Border Background="{DynamicResource SidebarBackgroundBrush}" Width="260">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Logo/Title -->
                <RowDefinition Height="*"/>      <!-- Menu Items -->
                <RowDefinition Height="Auto"/>   <!-- User Profile -->
                <RowDefinition Height="Auto"/>   <!-- Logout Button -->
            </Grid.RowDefinitions>

            <!-- Logo Section -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="32,30,24,24">
                <Path Data="{StaticResource IconBook}" 
                      Fill="{DynamicResource PrimaryPurpleActiveBrush}" 
                      Width="28" Height="28" 
                      Stretch="Uniform" 
                      VerticalAlignment="Center"/>
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="Book Management" 
                               Foreground="#FFFFFF" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               FontFamily="{DynamicResource MainFontFamily}"/>
                    <TextBlock Text="SYSTEM" 
                               Foreground="{DynamicResource PrimaryPurpleActiveBrush}" 
                               FontSize="11" 
                               FontWeight="Heavy" 
                               FontFamily="{DynamicResource MainFontFamily}"/>
                </StackPanel>
            </StackPanel>

            <!-- Menu ListBox -->
            <ListBox Grid.Row="1" 
                     ItemsSource="{Binding MenuItems}" 
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     Style="{StaticResource SidebarMenuListBoxStyle}"
                     ItemContainerStyle="{StaticResource SidebarMenuListBoxItemStyle}">
          
            </ListBox>

            <!-- User Profile Section -->
            <Border Grid.Row="2" 
                    Background="#191635" 
                    BorderBrush="#252148" 
                    BorderThickness="0,1,0,0" 
                    Padding="16" 
                    Margin="16,12,16,0" 
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Avatar placeholder -->
                    <Border Grid.Column="0" 
                            Width="40" Height="40" 
                            CornerRadius="20" 
                            Background="{DynamicResource PrimaryPurpleBrush}"
                            BorderBrush="{DynamicResource PrimaryPurpleActiveBrush}"
                            BorderThickness="1.5">
                        <!-- Displays first letter of username if avatar image is missing -->
                        <TextBlock Text="{Binding CurrentUser.Name[0]}" 
                                   Foreground="#FFFFFF" 
                                   FontWeight="Bold" 
                                   FontSize="16"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                    </Border>
                    
                    <!-- Username & Email -->
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUser.Name}" 
                                   Foreground="#FFFFFF" 
                                   FontSize="13" 
                                   FontWeight="SemiBold" 
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                        <TextBlock Text="{Binding CurrentUser.Email}" 
                                   Foreground="{DynamicResource TextSidebarBrush}" 
                                   FontSize="11" 
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Logout Button -->
            <Button Grid.Row="3" 
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource IconButton}" 
                    Width="Auto" Height="46"
                    Margin="16,12,16,24"
                    Padding="16,0" 
                    HorizontalAlignment="Stretch">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0"
                          Data="{StaticResource IconLogout}" 
                          Fill="{DynamicResource TextSidebarBrush}" 
                          Width="18" Height="18" 
                          Stretch="Uniform" 
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               Text="Logout" 
                               Foreground="{DynamicResource TextSidebarBrush}" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="{DynamicResource MainFontFamily}"/>
                </Grid>
            </Button>
        </Grid>
    </Border>
</UserControl>
