<UserControl x:Class="BookManagement.Controls.Pagination"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="600">
    <Grid Margin="12,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Showing range info text -->
        <TextBlock Grid.Column="0" 
                   Text="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=InfoText, FallbackValue='Showing 1 to 8 of 48 books'}" 
                   Style="{StaticResource TextBlockNormal}" 
                   VerticalAlignment="Center"/>

        <!-- Page buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Prev Button -->
            <Button Style="{StaticResource SecondaryButton}" Width="36" Padding="0" Height="36" Margin="0,0,8,0"
                    Click="BtnPrev_Click">
                <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
            </Button>
            
            <!-- Page Info Text -->
            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=PageInfoText, FallbackValue='Page 1 of 5'}" 
                       Style="{StaticResource TextBlockNormal}" 
                       VerticalAlignment="Center" 
                       Margin="8,0"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            
            <!-- Next Button -->
            <Button Style="{StaticResource SecondaryButton}" Width="36" Padding="0" Height="36" Margin="8,0,0,0"
                    Click="BtnNext_Click">
                <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
