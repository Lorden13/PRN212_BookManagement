<UserControl x:Class="BookManagement.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="42" d:DesignWidth="250">
    <Grid>
        <!-- TextBox wrapped inside -->
        <TextBox x:Name="txtSearch" 
                 Style="{StaticResource ModernTextBox}" 
                 Tag="{Binding RelativeSource={RelativeSource AncestorType=local:SearchBox}, Path=Tag}"
                 Padding="12,10,36,10"
                 Text="{Binding RelativeSource={RelativeSource AncestorType=local:SearchBox}, Path=Text, UpdateSourceTrigger=PropertyChanged}"/>
        
        <!-- Search Icon placed on the right -->
        <Path Data="{StaticResource IconSearch}" 
              Fill="{DynamicResource TextMutedBrush}" 
              Width="16" Height="16" 
              Stretch="Uniform" 
              HorizontalAlignment="Right" 
              VerticalAlignment="Center" 
              Margin="0,0,12,0"
              IsHitTestVisible="False"/>
    </Grid>
</UserControl>
