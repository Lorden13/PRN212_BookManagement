<UserControl x:Class="BookManagement.Controls.UserCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="300">
    <Border Style="{StaticResource BaseCardStyle}" Width="280" Height="150" Margin="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- User Avatar -->
            

            <!-- User Details -->
            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                <TextBlock Text="{Binding Name, FallbackValue='John Doe'}" 
                           Style="{StaticResource TextBlockBold}" 
                           FontSize="16"/>
                <TextBlock Text="{Binding Email, FallbackValue='user@email.com'}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           FontSize="{StaticResource FontSizeSmall}" 
                           Margin="0,2,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    
                    <TextBlock Text="{Binding Role, FallbackValue='User'}" 
                               Foreground="{DynamicResource PrimaryPurpleBrush}" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               FontWeight="SemiBold"
                               Margin="8,0,0,0" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding JoinedDate, StringFormat='Joined: {0}', FallbackValue='Joined: 2026-01-01'}" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           FontSize="{StaticResource FontSizeMuted}" 
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
