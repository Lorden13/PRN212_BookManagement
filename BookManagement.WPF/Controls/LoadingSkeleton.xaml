<UserControl x:Class="BookManagement.Controls.LoadingSkeleton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Border Style="{StaticResource BaseCardStyle}" Width="200" Height="280" Margin="10" x:Name="SkeletonBorder">
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="SkeletonBorder" 
                                         Storyboard.TargetProperty="Opacity" 
                                         From="0.4" To="0.85" 
                                         AutoReverse="True" 
                                         Duration="0:0:0.8"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>   <!-- Image skeleton -->
                <RowDefinition Height="Auto"/>  <!-- Category skeleton -->
                <RowDefinition Height="Auto"/>  <!-- Title skeleton -->
                <RowDefinition Height="Auto"/>  <!-- Subtitle skeleton -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Image Block -->
            <Border Grid.Row="0" CornerRadius="8" Background="#E5E7EB" Margin="0,0,0,12"/>

            <!-- Category -->
            <Border Grid.Row="1" Width="80" Height="14" CornerRadius="4" Background="#E5E7EB" HorizontalAlignment="Left" Margin="0,0,0,10"/>

            <!-- Title -->
            <Border Grid.Row="2" Height="18" CornerRadius="4" Background="#E5E7EB" Margin="0,0,0,8"/>

            <!-- Subtitle -->
            <Border Grid.Row="3" Width="120" Height="14" CornerRadius="4" Background="#E5E7EB" HorizontalAlignment="Left" Margin="0,0,0,12"/>
        </Grid>
    </Border>
</UserControl>
