<UserControl x:Class="BookManagement.Controls.Header"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="800">
    <Border Style="{StaticResource HeaderContainerStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Page Title -->
                <ColumnDefinition Width="*"/>      <!-- Injected Content -->
                <ColumnDefinition Width="Auto"/>   <!-- Search / Notifications / User -->
            </Grid.ColumnDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Column="0" 
                       Text="{Binding PageTitle, FallbackValue='Dashboard'}" 
                       Style="{StaticResource TextBlockMediumHeader}" 
                       VerticalAlignment="Center"/>

            <!-- Injected Content Area (Allows future pages to inject custom buttons/filters) -->
            <ContentControl Grid.Column="1" 
                            Content="{Binding RelativeSource={RelativeSource AncestorType=local:Header}, Path=HeaderContent}" 
                            VerticalAlignment="Center" 
                            Margin="20,0"/>

            <!-- Right Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Reusable Search Box -->
                <local:SearchBox Width="220" Margin="0,0,16,0" VerticalAlignment="Center" Tag="Tìm kiếm sách, tác giả..."/>
                
                <!-- Notification Button with badge count -->
                <local:NotificationButton Margin="0,0,16,0"/>

                <!-- Divider -->
                <Border Width="1" Height="24" Background="{DynamicResource BorderBrush}" Margin="0,0,16,0"/>

                <!-- User Profile quick info -->
                <StackPanel Orientation="Horizontal">
                    <local:AvatarCard Width="36" Height="36" 
                                      VerticalAlignment="Center"
                                      DataContext="{Binding Sidebar.CurrentUser}"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Sidebar.CurrentUser.Name, FallbackValue='John Doe'}" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                        <TextBlock Text="{Binding Sidebar.CurrentUser.Role, FallbackValue='Reader'}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="11"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                    </StackPanel>
                </StackPanel>
                
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
