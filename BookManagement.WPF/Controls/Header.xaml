<UserControl x:Class="BookManagement.Controls.Header"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Add standard geometry icon since we might need it -->
    </UserControl.Resources>
    <Border Style="{StaticResource HeaderContainerStyle}" Loaded="UserControl_Loaded">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Page Title -->
                <ColumnDefinition Width="*"/>      <!-- Injected Content -->
                <ColumnDefinition Width="Auto"/>   <!-- Search / Notifications / User -->
            </Grid.ColumnDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Column="0" 
                       x:Name="txtPageTitle"
                       Text="Dashboard" 
                       Style="{StaticResource TextBlockMediumHeader}" 
                       VerticalAlignment="Center"/>

            <!-- Injected Content Area -->
            <ContentControl Grid.Column="1" 
                             Content="{Binding RelativeSource={RelativeSource AncestorType=local:Header}, Path=HeaderContent}" 
                             VerticalAlignment="Center" 
                             Margin="20,0"/>

            <!-- Right Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Reusable Search Box -->
                <local:SearchBox Width="220" Margin="0,0,16,0" VerticalAlignment="Center" Tag="Tìm kiếm sách, tác giả..."/>
                
                <!-- Notification Button -->
                <local:NotificationButton Margin="0,0,16,0" Visibility="Collapsed"/>

                <!-- Divider -->
                <Border Width="1" Height="24" Background="{DynamicResource BorderBrush}" Margin="0,0,16,0"/>

                <!-- User Profile quick info -->
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryPurpleBrush}" BorderBrush="{DynamicResource PrimaryPurpleActiveBrush}" BorderThickness="1" VerticalAlignment="Center">
                        <TextBlock x:Name="txtAvatarLetter" Text="U" Foreground="#FFFFFF" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource MainFontFamily}"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtUserName" 
                                   Text="User Name" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                        <TextBlock x:Name="txtUserRole" 
                                   Text="Role" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="11"
                                   FontFamily="{DynamicResource MainFontFamily}"/>
                    </StackPanel>
                </StackPanel>
                
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
