<UserControl x:Class="BookManagement.Controls.SectionTitle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="300">
    <Grid Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal">
            <!-- Left Accent Line -->
            <Border Width="4" Height="18" 
                    Background="{DynamicResource PrimaryPurpleBrush}" 
                    CornerRadius="2" 
                    VerticalAlignment="Center" 
                    Margin="0,0,10,0"/>
            
            <!-- Title Text -->
            <TextBlock 
                       Style="{StaticResource TextBlockSmallHeader}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
