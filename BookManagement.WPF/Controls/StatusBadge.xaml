<UserControl x:Class="BookManagement.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="100">
    <UserControl.Template>
        <ControlTemplate TargetType="UserControl">
            <Border CornerRadius="12" 
                    Padding="12,4" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center"
                    Background="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StatusToBgBrushConv}}"
                    BorderBrush="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StatusToBrushConv}}"
                    BorderThickness="1">
                <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" 
                           Foreground="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource StatusToBrushConv}}" 
                           FontSize="12" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           FontFamily="{DynamicResource MainFontFamily}"/>
            </Border>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
