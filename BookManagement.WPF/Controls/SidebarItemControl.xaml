<UserControl x:Class="BookManagement.Controls.SidebarItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="200">
    <Grid MinHeight="24" Background="Transparent" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Icon -->
        <Path Grid.Column="0"
              Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
              Width="18" Height="18" 
              Stretch="Uniform"
              HorizontalAlignment="Center" 
              VerticalAlignment="Center"/>

        <!-- Title -->
        <TextBlock Grid.Column="1" 
                   Text="{Binding Title}" 
                   VerticalAlignment="Center" 
                   Margin="12,0,0,0" 
                   FontFamily="{DynamicResource MainFontFamily}"
                   FontSize="{DynamicResource FontSizeNormal}"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
