<UserControl x:Class="BookManagement.Controls.StatisticCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="220">
    <Border Style="{StaticResource BaseCardStyle}" Margin="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Title -->
                <RowDefinition Height="*"/>      <!-- Value -->
                <RowDefinition Height="Auto"/>   <!-- Trend / Subtext -->
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{Binding RelativeSource={RelativeSource AncestorType=local:StatisticCard}, Path=Title, FallbackValue='Total Books'}" 
                       Foreground="{DynamicResource TextSecondaryBrush}" 
                       FontSize="{StaticResource FontSizeSmall}"
                       FontFamily="{DynamicResource MainFontFamily}"/>

            <!-- Icon (on the right) -->
            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                    Width="40" Height="40" 
                    CornerRadius="8" 
                    Background="{DynamicResource PrimaryPurpleLightBrush}" 
                    VerticalAlignment="Top">
                <Path Data="{Binding RelativeSource={RelativeSource AncestorType=local:StatisticCard}, Path=IconKey, Converter={StaticResource ResKeyToGeomConv}}" 
                      Fill="{DynamicResource PrimaryPurpleBrush}" 
                      Width="20" Height="20" 
                      Stretch="Uniform" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Value -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="{Binding RelativeSource={RelativeSource AncestorType=local:StatisticCard}, Path=Value, FallbackValue='12'}" 
                       Style="{StaticResource TextBlockMediumHeader}"
                       VerticalAlignment="Center"/>

            <!-- Trend / Subtext -->
            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding RelativeSource={RelativeSource AncestorType=local:StatisticCard}, Path=TrendText, FallbackValue='View all'}" 
                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:StatisticCard}, Path=TrendBrush, FallbackValue={StaticResource TextMutedBrush}}" 
                       FontSize="{StaticResource FontSizeMuted}"
                       FontWeight="SemiBold"
                       FontFamily="{DynamicResource MainFontFamily}"/>
        </Grid>
    </Border>
</UserControl>
