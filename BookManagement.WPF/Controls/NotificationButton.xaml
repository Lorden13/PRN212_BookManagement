<UserControl x:Class="BookManagement.Controls.NotificationButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="40">
    <Grid>
        <!-- Bell Icon Button -->
        <Button Style="{StaticResource IconButton}">
            <Path Data="{StaticResource IconBell}" 
                  Fill="{DynamicResource TextSecondaryBrush}" 
                  Width="20" Height="20" 
                  Stretch="Uniform"/>
        </Button>
        
        <!-- Red Notification Badge Dot -->
        <Border Background="{DynamicResource DangerBrush}" 
                BorderBrush="#FFFFFF" 
                BorderThickness="1.5" 
                Width="9" Height="9" 
                CornerRadius="4.5" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="0,6,8,0"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
