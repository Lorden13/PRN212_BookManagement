<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base Card Style (Static Border representation of a Card) -->
    <Style x:Key="BaseCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect x:Name="shadow" BlurRadius="6" ShadowDepth="1" Color="#000000" Opacity="0.04" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Hover Card Style (animates shadow on hover) -->
    <Style x:Key="HoverCardStyle" TargetType="Border" BasedOn="{StaticResource BaseCardStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#D1D5DB"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Color="#000000" Opacity="0.08" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Info/Statistic Card Style (colored left border accent) -->
    <Style x:Key="AccentCardStyle" TargetType="Border" BasedOn="{StaticResource BaseCardStyle}">
        <Setter Property="BorderThickness" Value="4,1,1,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPurpleBrush}"/>
    </Style>
</ResourceDictionary>
