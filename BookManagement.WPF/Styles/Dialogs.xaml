<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Modal Dialog Overlay Background -->
    <Style x:Key="DialogOverlayStyle" TargetType="Grid">
        <Setter Property="Background" Value="#990F172A"/> <!-- Semi-transparent dark slate -->
    </Style>

    <!-- Dialog Window / Content Card Style -->
    <Style x:Key="DialogCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Width" Value="420"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Color="#000000" Opacity="0.15" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dialog Icon Border (Circle around warning/success/error icon) -->
    <Style x:Key="DialogIconCircleStyle" TargetType="Border">
        <Setter Property="Width" Value="56"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="CornerRadius" Value="28"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
</ResourceDictionary>
