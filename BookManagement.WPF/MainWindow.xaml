<Window x:Class="BookManagement.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BookManagement.WPF.ViewModels"
        Title="Book Management System"
        Width="1320" Height="800"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Auth pages (full screen, no sidebar/header) -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVis}}"/>

        <!-- Main Layout -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════ -->
            <!-- SIDEBAR                                    -->
            <!-- ══════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
                <DockPanel>
                    <!-- Brand -->
                    <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="BookManager"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="{StaticResource FontSizeMedium}"
                                           FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Management System"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="{StaticResource FontSizeXS}"
                                           Foreground="{StaticResource SidebarTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Separator -->
                    <Border DockPanel.Dock="Top" Height="1" Margin="20,0">
                        <Border.Background>
                            <SolidColorBrush Color="White" Opacity="0.06"/>
                        </Border.Background>
                    </Border>

                    <!-- Navigation Label -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="NAVIGATION"
                               FontFamily="{StaticResource DefaultFont}"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource SidebarTextBrush}"
                               Margin="24,20,0,8" Opacity="0.6"/>

                    <!-- Logout -->
                    <Border DockPanel.Dock="Bottom" Padding="8,8,8,20">
                        <Border BorderThickness="0,1,0,0" Padding="0,12,0,0">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="White" Opacity="0.06"/>
                            </Border.BorderBrush>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding LogoutCommand}"
                                    Foreground="#EF4444">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Logout" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Border>

                    <!-- Menu Items -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Tag}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityToBool}">
                                                                <Binding Path="Tag"/>
                                                                <Binding Path="DataContext.SelectedMenuItem.Tag" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBgBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ══════════════════════════════════════════ -->
            <!-- MAIN AREA                                  -->
            <!-- ══════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="28,0">
                    <Grid Height="60">
                        <!-- Page Title -->
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontFamily="{StaticResource DefaultFont}"
                                   FontSize="{StaticResource FontSizeLarge}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>

                        <!-- User Info -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Avatar -->
                            <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{Binding UserInitials}"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Name & Role -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{Binding UserFullName}"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding UserRoleDisplay}"
                                           FontFamily="{StaticResource DefaultFont}"
                                           FontSize="{StaticResource FontSizeXS}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Width="1" Height="24" Margin="0,0,16,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#E2E8F0"/>
                                </Border.Background>
                            </Border>

                            <!-- Logout -->
                            <Button Style="{StaticResource LinkButton}"
                                    Content="Sign out"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    Command="{Binding LogoutCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
