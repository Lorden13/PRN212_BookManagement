<UserControl x:Class="BookManagement.Views.Admin.AdminPurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Statistics Cards -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Purchase Statistics Cards -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="-8,0,-8,20">
            <controls:StatisticCard Title="Tổng doanh thu" Value="{Binding TotalRevenue, StringFormat='${0:F2}'}" IconKey="IconCart" TrendText="Từ giao dịch thành công" TrendBrush="{DynamicResource SuccessBrush}"/>
            <controls:StatisticCard Title="Tổng số giao dịch" Value="{Binding TotalTransactions}" IconKey="IconChart" TrendText="Tất cả trạng thái"/>
            <controls:StatisticCard Title="Giao dịch thành công" Value="{Binding CompletedCount}" IconKey="IconCheck" TrendText="Completed" TrendBrush="{DynamicResource SuccessBrush}"/>
            <controls:StatisticCard Title="Giao dịch đã hủy" Value="{Binding CancelledCount}" IconKey="IconClose" TrendText="Cancelled" TrendBrush="{DynamicResource DangerBrush}"/>
        </UniformGrid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource BaseCardStyle}" Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/> <!-- Reader Filter -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/> <!-- Status Filter -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Width="300" HorizontalAlignment="Left">
                    <TextBox Style="{StaticResource ModernTextBox}" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Tag="Tìm kiếm theo tiêu đề sách, tên độc giả..."/>
                    <Path Data="{StaticResource IconSearch}" 
                          Fill="{DynamicResource TextMutedBrush}" 
                          Width="16" Height="16" Stretch="Uniform" 
                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" 
                          IsHitTestVisible="False"/>
                </Grid>

                <!-- Reader Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Độc giả:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox ItemsSource="{Binding Readers}" SelectedItem="{Binding SelectedReader}" Width="180" Style="{StaticResource ModernComboBox}"/>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource TextBlockNormal}"/>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Width="150" Style="{StaticResource ModernComboBox}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid of Transactions -->
        <Border Grid.Row="2" Style="{StaticResource BaseCardStyle}" Padding="20">
            <Grid>
                <DataGrid ItemsSource="{Binding PurchasesView}" Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <!-- Order ID -->
                        <DataGridTextColumn Header="Mã giao dịch" Binding="{Binding Id, StringFormat='#TXN{0:D5}'}" Width="1.5*"/>

                        <!-- Reader -->
                        <DataGridTextColumn Header="Độc giả" Binding="{Binding ReaderName}" Width="2*"/>

                        <!-- Book Title -->
                        <DataGridTemplateColumn Header="Sách" Width="3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BookTitle}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Price -->
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding Price, StringFormat='${0:F2}'}" Width="1.2*"/>

                        <!-- Purchase Date -->
                        <DataGridTextColumn Header="Ngày giao dịch" Binding="{Binding PurchaseDate}" Width="1.8*"/>

                        <!-- Status Badge -->
                        <DataGridTemplateColumn Header="Trạng thái" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadge Content="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Thao tác" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OutlinedButton}" Content="Chi tiết" Height="28" Padding="12,0"
                                            Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <controls:EmptyState>
                    <controls:EmptyState.Style>
                        <Style TargetType="controls:EmptyState">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PurchasesView.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:EmptyState.Style>
                </controls:EmptyState>
            </Grid>
        </Border>
    </Grid>
</UserControl>
