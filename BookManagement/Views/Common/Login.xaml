<Page x:Class="BookManagement.Views.Common.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BookManagement.Views"
      xmlns:vm="clr-namespace:BookManagement.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="Đăng nhập"
      Style="{StaticResource PageLoadStyle}">


    <Grid Background="#F8F9FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/> <!-- Left Splash -->
            <ColumnDefinition Width="2*"/> <!-- Right Login Buttons -->
        </Grid.ColumnDefinitions>

        <!-- Left Splash Panel (Purple Gradient and Branding) -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B21B6" Offset="0.0"/> <!-- Deep Purple -->
                    <GradientStop Color="#7C3AED" Offset="0.6"/> <!-- Medium Purple -->
                    <GradientStop Color="#A78BFA" Offset="1.0"/> <!-- Light Purple Accent -->
                </LinearGradientBrush>
            </Border.Background>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50">
                <StackPanel MaxWidth="500">
                    <!-- Logo Icon -->
                    <Border Width="80" Height="80" CornerRadius="40" Background="#33FFFFFF" Margin="0,0,0,24" HorizontalAlignment="Left">
                        <Path Data="{StaticResource IconBook}" 
                              Fill="#FFFFFF" 
                              Width="40" Height="40" 
                              Stretch="Uniform"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Border>
                    <!-- App Title -->
                    <TextBlock Text="Hệ thống Quản lý Sách" 
                               Foreground="#FFFFFF" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <TextBlock Text="BOOK MANAGEMENT SYSTEM" 
                               Foreground="#E9D5FF" 
                               FontSize="14" 
                               FontWeight="Heavy" 
                               Margin="0,4,0,20"
                               FontFamily="{StaticResource MainFontFamily}"/>
                    <!-- Slogan/Description -->
                    <TextBlock Text="Nền tảng kết nối Độc giả, Tác giả và Ban quản trị. Trải nghiệm tìm kiếm, đăng tải và kiểm duyệt sách thông minh, trực quan và tối ưu nhất." 
                               Foreground="#F3E8FF" 
                               FontSize="15" 
                               LineHeight="24"
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource MainFontFamily}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel (Login Actions) -->
        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
            <StackPanel Width="360">
                <!-- Welcome header -->
                <TextBlock Text="Welcome back!" 
                           Style="{StaticResource TextBlockLargeHeader}" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="Vui lòng lựa chọn vai trò Demo để tiếp tục khám phá hệ thống." 
                           Style="{StaticResource TextBlockNormal}" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,32"/>

                <!-- Login options -->
                <StackPanel>
                    <!-- Login as Reader -->
                    <Button Command="{Binding LoginReaderCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            Height="50"
                            Margin="0,0,0,16">
                        <Grid HorizontalAlignment="Stretch" Width="300">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconUser}" Fill="#FFFFFF" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Đăng nhập làm Độc giả" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                        </Grid>
                    </Button>

                    <!-- Login as Author -->
                    <Button Command="{Binding LoginAuthorCommand}"
                            Style="{StaticResource OutlinedButton}" 
                            Height="50"
                            Margin="0,0,0,16">
                        <Grid HorizontalAlignment="Stretch" Width="300">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconEdit}" Fill="{DynamicResource PrimaryPurpleBrush}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Đăng nhập làm Tác giả" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                        </Grid>
                    </Button>

                    <!-- Login as Admin -->
                    <Button Command="{Binding LoginAdminCommand}"
                            Style="{StaticResource SecondaryButton}" 
                            Height="50">
                        <Grid HorizontalAlignment="Stretch" Width="300">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource IconShield}" Fill="{DynamicResource TextPrimaryBrush}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Đăng nhập làm Quản trị viên" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Footer disclaimer -->
                <TextBlock Text="* Phiên bản Demo không yêu cầu tài khoản và mật khẩu." 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           FontSize="12" 
                           HorizontalAlignment="Center" 
                           Margin="0,48,0,0"
                           FontStyle="Italic"
                           FontFamily="{StaticResource MainFontFamily}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
