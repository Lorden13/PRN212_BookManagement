<UserControl x:Class="BookManagement.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BookManagement.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
            <!-- Icon -->
            <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource PrimaryPurpleLightBrush}" Margin="0,0,0,16" HorizontalAlignment="Center">
                <Path Data="{StaticResource IconBooks}" 
                      Fill="{DynamicResource PrimaryPurpleBrush}" 
                      Width="32" Height="32" 
                      Stretch="Uniform"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Title -->
            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=local:EmptyState}, Path=Title, FallbackValue='Không tìm thấy kết quả'}" 
                       Style="{StaticResource TextBlockSmallHeader}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,8"/>

            <!-- Message -->
            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=local:EmptyState}, Path=Message, FallbackValue='Vui lòng thử lại với từ khóa khác hoặc thiết lập lại bộ lọc.'}" 
                       Style="{StaticResource TextBlockNormal}" 
                       TextAlignment="Center" 
                       Width="280" 
                       TextWrapping="Wrap" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Action Button (optional) -->
            <Button Style="{StaticResource SecondaryButton}" 
                    Content="{Binding RelativeSource={RelativeSource AncestorType=local:EmptyState}, Path=ActionText, FallbackValue='Làm mới'}" 
                    Height="36" 
                    HorizontalAlignment="Center"
                    Visibility="{Binding RelativeSource={RelativeSource AncestorType=local:EmptyState}, Path=ShowAction, Converter={StaticResource BoolToVisConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
